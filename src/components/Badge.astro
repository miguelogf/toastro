---
interface Props {
  label: string;
  type?:
    | "default"
    | "success"
    | "warning"
    | "error"
    | "info"
    | "neutral"
    | "brand";
  variant?: "basic" | "solid" | "soft" | "outline" | "glass" | "gradient";
  color?: string;
  gradientColors?: string[];
  textColor?: string;
  class?: string;
}

const {
  label,
  type = "default",
  variant = "soft", // soft es el default más versátil
  color,
  gradientColors = ["#f97316", "#f31b75"],
  textColor,
  class: className = "",
} = Astro.props;

// Solo necesario para variant solid — contraste automático
function contrastColor(hex: string): string {
  const h = hex.replace("#", "");
  const r = parseInt(h.slice(0, 2), 16);
  const g = parseInt(h.slice(2, 4), 16);
  const b = parseInt(h.slice(4, 6), 16);
  return (r * 299 + g * 587 + b * 114) / 1000 >= 150 ? "#000000" : "#ffffff";
}

const resolvedTextColor =
  textColor ?? (color ? contrastColor(color) : undefined);
const gradient = `linear-gradient(90deg, ${gradientColors.join(", ")})`;

const style = [
  color && `--type-color: ${color}`,
  resolvedTextColor && `--type-text: ${resolvedTextColor}`,
  `--gradient-colors: ${gradient}`,
]
  .filter(Boolean)
  .join("; ");
---

<span
  class:list={["badge", `type--${type}`, `variant--${variant}`, className]}
  style={style}
>
  {label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.25rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 500;
    font-family: var(--font-code);
    border-radius: 999px;
    line-height: 1;
    border: 1px solid transparent;
    vertical-align: middle;

    /* Fallback si no viene tipo */
    --type-color: var(--status-default);
  }
</style>
