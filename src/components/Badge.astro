---
interface Props {
  label: string;
  variant?: "default" | "success" | "warning" | "danger" | "info" | "accent";
  theme?: "solid" | "outline" | "gradient";
  color?: string;
  gradientColors?: string[];
  textColor?: string;
}

const {
  label,
  variant = "default",
  theme = "solid",
  color,
  gradientColors = ["#6366f1", "#ec4899"],
  textColor,
} = Astro.props;

const gradient = `linear-gradient(90deg, ${gradientColors.join(",")})`;

const style = `
  ${color ? `--variant-color: ${color};` : ""}
  ${textColor ? `--badge-text: ${textColor};` : ""}
  --badge-gradient: ${gradient};
`;
---

<span class={`badge variant variant--${variant} theme--${theme}`} style={style}>
  {label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 300;
    border-radius: 999px;
    line-height: 1;
    border: 1px solid transparent;
    color: var(--variant-color);
  }
</style>
