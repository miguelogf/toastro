---
// src/components/Builder.astro
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import Badge from "./Badge.astro";
import Section from "./Section.astro";

const exampleGroups = [
  {
    label: "Toast Variants",
    examples: [
      {
        id: "e-glass",
        label: "Glass",
        config: {
          message: "Lorem Ipsum is simply dummy text of the printing industry.",
          variant: "glass",
        },
      },
      {
        id: "e-subtle",
        label: "Subtle",
        config: {
          message: "Successfully deployed to Vercel",
          type: "success",
          variant: "subtle",
        },
      },
      {
        id: "e-soft",
        label: "Soft",
        config: {
          message: "Warning: Low disk space",
          type: "info",
          variant: "soft",
        },
      },
      {
        id: "e-outline",
        label: "Outline",
        config: {
          message: "Thanks for the support!",
          type: "brand",
          variant: "outline",
        },
      },
      {
        id: "e-solid",
        label: "Solid",
        config: {
          message: "New update available",
          type: "neutral",
          variant: "solid",
        },
      },
      {
        id: "e-gradient",
        label: "Gradient",
        config: {
          message: "🍞✨ A minimal toast for Astro",
          noIcon: true,
          variant: "gradient",
          gradientColors: ["#6366f1", "#f31b75"],
        },
      },
    ],
  },
  {
    label: "Toast Types",
    examples: [
      {
        id: "t-success",
        label: "Success",
        config: {
          message: "Changes saved!",
          type: "success",
          variant: "solid",
        },
      },
      {
        id: "t-error",
        label: "Error",
        config: {
          message: "Something went wrong",
          type: "error",
          variant: "solid",
        },
      },
      {
        id: "t-warning",
        label: "Warning",
        config: {
          message: "Your session is about to expire",
          type: "warning",
          variant: "solid",
        },
      },
      {
        id: "t-info",
        label: "Info",
        config: {
          message: "A new version is available",
          type: "info",
          variant: "solid",
        },
      },
      {
        id: "t-neutral",
        label: "Neutral",
        config: {
          message: "Processing your request…",
          type: "neutral",
          variant: "solid",
        },
      },
      {
        id: "t-brand",
        label: "Brand",
        config: {
          message: "Welcome to toastro 🍞",
          type: "brand",
          variant: "solid",
        },
      },
    ],
  },
  {
    label: "Custom",
    examples: [
      {
        id: "c-no-icon",
        label: "No icon",
        config: {
          message: "Clean, iconless toast",
          noIcon: true,
          variant: "soft",
          type: "neutral",
        },
      },
      {
        id: "c-quick",
        label: "Quick",
        config: {
          message: "Copied!",
          type: "success",
          variant: "subtle",
          duration: 1500,
        },
      },
      {
        id: "c-persist",
        label: "Persistent",
        config: {
          message: "Don't forget to save your work",
          type: "warning",
          variant: "outline",
          duration: 8000,
        },
      },
      {
        id: "c-long",
        label: "Long message",
        config: {
          message:
            "Your file has been uploaded and processed. Share it with your team.",
          type: "success",
          variant: "glass",
        },
      },
    ],
  },
];

const TYPE_COLORS: Record<string, string> = {
  success: "#34d399",
  error: "#e53935",
  warning: "#ed931b",
  info: "#2563eb",
  neutral: "#808ea2",
  brand: "#f31b75",
  default: "#808ea2",
};

const VARIANTS = [
  "solid",
  "soft",
  "subtle",
  "outline",
  "ghost",
  "surface",
  "glass",
  "gradient",
];
const TYPES = ["success", "error", "warning", "info", "neutral", "brand"];
---

<Section
  id="builder"
  label="Try it out"
  title="Build your <em>toast</em>."
  subtitle="Configure from scratch or pick a ready-made example. Click to fire."
  class="builder-section"
>
  <div class="builder-root">
    <!-- LEFT: Controls -->
    <aside class="panel controls-panel">
      <div class="panel-hdr">
        <Icon name="bolt" />
        Builder
      </div>

      <!-- Type -->
      <div class="ctrl">
        <div class="ctrl-hd">
          Type <Badge variant="outline" class="badge--xs" id="lbl-type"
            >success</Badge
          >
        </div>
        <div class="type-grid">
          {
            TYPES.map((t) => (
              <label
                class="type-chip"
                data-type={t}
                style={`--cc:${TYPE_COLORS[t]}`}
              >
                <input
                  type="radio"
                  name="b-type"
                  value={t}
                  checked={t === "success"}
                  class="sr-only"
                />
                <span class="chip-dot" />
                <span class="chip-txt">{t}</span>
              </label>
            ))
          }
        </div>
      </div>

      <!-- Variant -->
      <div class="ctrl">
        <div class="ctrl-hd">
          Variant <Badge variant="outline" class="badge--xs" id="lbl-variant"
            >solid</Badge
          >
        </div>
        <div class="variant-grid">
          {
            VARIANTS.map((v) => (
              <label class="v-pill" data-variant={v}>
                <input
                  type="radio"
                  name="b-variant"
                  value={v}
                  checked={v === "solid"}
                  class="sr-only"
                />
                {v}
              </label>
            ))
          }
        </div>
      </div>

      <!-- Message -->
      <div class="ctrl">
        <div class="ctrl-hd">Message</div>
        <div class="inp-wrap">
          <input
            id="b-msg"
            class="msg-inp"
            type="text"
            value="Saved successfully 🍞"
            maxlength="80"
          />
          <span class="char-ct" id="char-count">22/80</span>
        </div>
      </div>

      <!-- Duration -->
      <div class="ctrl">
        <div class="ctrl-hd">
          Duration <Badge variant="outline" class="badge--xs">4000ms</Badge>
        </div>
        <input
          id="b-dur"
          class="range-sl"
          type="range"
          min="1000"
          max="10000"
          step="500"
          value="4000"
        />
        <div class="range-tks">
          <span>1s</span><span>5s</span><span>10s</span>
        </div>
      </div>

      <!-- Icon toggle -->
      <div class="ctrl ctrl-row">
        <div class="ctrl-hd" style="margin:0">Show icon</div>
        <button class="toggle" id="b-icon-tg" role="switch" aria-checked="true">
          <span class="tg-thumb"></span>
        </button>
      </div>

      <!-- Fire -->
      <div class="ctrl" style="padding-top:.5rem">
        <Button id="builder-fire" style="width: 100%;">
          Fire toast <Icon name="flame" />
        </Button>
        <Button variant="outline" type="reset" style="width: 100%"
          >Reset <Icon name="reload" /></Button
        >
      </div>
    </aside>

    <!-- RIGHT -->
    <div class="right-col">
      <!-- Examples -->
      <div class="panel examples-panel">
        <div class="ep-hd">
          <span class="ep-title">Examples</span>
          <span class="ep-hint">Click to preview</span>
        </div>
        {
          exampleGroups.map((group) => (
            <div class="eg-group">
              <div class="eg-lbl">{group.label}</div>
              <div class="eg-pills">
                {group.examples.map((ex) => {
                  const cfg = ex.config as any;
                  const tc = TYPE_COLORS[cfg.type ?? "default"] ?? "#808ea2";
                  return (
                    <button
                      class="eg-pill"
                      data-cfg={JSON.stringify(cfg)}
                      style={`--tc:${tc}`}
                    >
                      <span class="eg-dot" />
                      {ex.label}
                      {cfg.duration && cfg.duration !== 4000 && (
                        <span class="eg-badge">{cfg.duration / 1000}s</span>
                      )}
                    </button>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Code -->
      <div class="panel code-panel">
        <div class="cp-hd">
          <div class="cp-lang">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              width="12"
              height="12"
            >
              <polyline points="16 18 22 12 16 6"></polyline><polyline
                points="8 6 2 12 8 18"></polyline>
            </svg>
            JavaScript
          </div>
          <button class="copy-btn" id="copy-code">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="12"
              height="12"
            >
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
              ></path>
            </svg>
            <span id="copy-lbl">Copy</span>
          </button>
        </div>
        <pre class="code-pre"><code id="code-out" /></pre>
      </div>
    </div>
  </div>
</Section>

<script is:inline>
  (function () {
    var state = {
      type: "success",
      variant: "solid",
      message: "Saved successfully 🍞",
      duration: 4000,
      showIcon: true,
      noIcon: false,
      gradientColors: null,
    };

    var TYPE_COLORS = {
      success: "#34d399",
      error: "#e53935",
      warning: "#ed931b",
      info: "#2563eb",
      neutral: "#808ea2",
      brand: "#f31b75",
      default: "#808ea2",
    };

    function buildCode() {
      var l = ["window.showToast({"];
      l.push(
        '  message: "' +
          state.message.replace(/\\/g, "\\\\").replace(/"/g, '\\"') +
          '",',
      );
      if (state.type !== "success") l.push('  type: "' + state.type + '",');
      if (state.variant !== "solid")
        l.push('  variant: "' + state.variant + '",');
      if (state.noIcon || !state.showIcon) l.push("  icon: null,");
      if (state.gradientColors)
        l.push(
          "  gradientColors: " + JSON.stringify(state.gradientColors) + ",",
        );
      if (state.duration !== 4000)
        l.push("  duration: " + state.duration + ",");
      l.push("});");
      return l.join("\n");
    }

    function hl(s) {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\b(window)\b/g, '<span class="c-obj">$1</span>')
        .replace(/\b(showToast)\b/g, '<span class="c-fn">$1</span>')
        .replace(
          /\b(message|type|variant|icon|duration|gradientColors)\b(?=:)/g,
          '<span class="c-key">$1</span>',
        )
        .replace(/("(?:[^"\\]|\\.)*")/g, '<span class="c-str">$1</span>')
        .replace(/\b(\d+)\b/g, '<span class="c-num">$1</span>')
        .replace(/\b(null)\b/g, '<span class="c-kw">$1</span>');
    }

    function updateCode() {
      var el = document.getElementById("code-out");
      if (el) el.innerHTML = hl(buildCode());
    }

    function fire() {
      if (typeof window.showToast !== "function") return;
      var p = {
        message: state.message,
        type: state.type,
        variant: state.variant,
        duration: state.duration,
      };
      if (state.noIcon || !state.showIcon) p.icon = null;
      if (state.gradientColors) p.gradientColors = state.gradientColors;
      window.showToast(p);
    }

    function syncUI() {
      document.querySelectorAll(".type-chip").forEach(function (c) {
        c.classList.toggle("type-chip--on", c.dataset.type === state.type);
      });
      document.querySelectorAll(".v-pill").forEach(function (p) {
        p.classList.toggle("v-pill--on", p.dataset.variant === state.variant);
      });
      var e;
      if ((e = document.getElementById("lbl-type"))) e.textContent = state.type;
      if ((e = document.getElementById("lbl-variant")))
        e.textContent = state.variant;
      if ((e = document.getElementById("lbl-dur")))
        e.textContent = state.duration + "ms";
      if ((e = document.getElementById("b-msg"))) e.value = state.message;
      if ((e = document.getElementById("char-count")))
        e.textContent = state.message.length + "/80";
      if ((e = document.getElementById("b-dur"))) e.value = state.duration;
      var tg = document.getElementById("b-icon-tg");
      if (tg) {
        var on = state.showIcon && !state.noIcon;
        tg.setAttribute("aria-checked", String(on));
        tg.classList.toggle("toggle--off", !on);
      }
    }

    function render() {
      syncUI();
      updateCode();
    }

    // Type radios
    document.querySelectorAll("input[name='b-type']").forEach(function (inp) {
      inp.addEventListener("change", function (e) {
        state.type = e.target.value;
        render();
      });
    });

    // Variant radios
    document
      .querySelectorAll("input[name='b-variant']")
      .forEach(function (inp) {
        inp.addEventListener("change", function (e) {
          state.variant = e.target.value;
          render();
        });
      });

    // Message
    var msgEl = document.getElementById("b-msg");
    if (msgEl)
      msgEl.addEventListener("input", function (e) {
        state.message = e.target.value;
        var cc = document.getElementById("char-count");
        if (cc) cc.textContent = state.message.length + "/80";
        updateCode();
      });

    // Duration
    var durEl = document.getElementById("b-dur");
    if (durEl)
      durEl.addEventListener("input", function (e) {
        state.duration = parseInt(e.target.value);
        var ld = document.getElementById("lbl-dur");
        if (ld) ld.textContent = state.duration + "ms";
        updateCode();
      });

    // Icon toggle
    var tgEl = document.getElementById("b-icon-tg");
    if (tgEl)
      tgEl.addEventListener("click", function () {
        state.showIcon = !state.showIcon;
        state.noIcon = !state.showIcon;
        tgEl.setAttribute("aria-checked", String(state.showIcon));
        tgEl.classList.toggle("toggle--off", !state.showIcon);
        updateCode();
      });

    // Builder fire
    var fbEl = document.getElementById("builder-fire");
    if (fbEl)
      fbEl.addEventListener("click", function () {
        fire();
        fbEl.classList.add("firing");
        setTimeout(function () {
          fbEl.classList.remove("firing");
        }, 600);
      });

    // Example pills
    document.querySelectorAll(".eg-pill").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var cfg;
        try {
          cfg = JSON.parse(btn.dataset.cfg);
        } catch (e) {
          return;
        }

        state.message = cfg.message || "";
        state.type = cfg.type || "default";
        state.variant = cfg.variant || "solid";
        state.duration = cfg.duration || 4000;
        state.gradientColors = cfg.gradientColors || null;
        state.noIcon = !!cfg.noIcon;
        state.showIcon = !state.noIcon;

        document.querySelectorAll(".eg-pill").forEach(function (p) {
          p.classList.remove("eg-pill--active");
        });
        btn.classList.add("eg-pill--active");

        fire();
        render();
      });
    });

    // Copy
    var cpBtn = document.getElementById("copy-code");
    var cpLbl = document.getElementById("copy-lbl");
    if (cpBtn)
      cpBtn.addEventListener("click", function () {
        navigator.clipboard.writeText(buildCode()).then(function () {
          if (cpLbl) cpLbl.textContent = "Copied!";
          cpBtn.classList.add("copied");
          setTimeout(function () {
            if (cpLbl) cpLbl.textContent = "Copy";
            cpBtn.classList.remove("copied");
          }, 2000);
        });
      });

    render();
  })();
</script>

<style>
  /* ── Layout ──────────────────────────────────────────── */
  .builder-root {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1rem;
    align-items: start;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Panel base ──────────────────────────────────────── */
  .panel {
    background: color-mix(in srgb, var(--text) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 9%, transparent);
    border-radius: 14px;
    overflow: hidden;
  }

  /* ── Controls ────────────────────────────────────────── */
  .controls-panel {
    display: flex;
    flex-direction: column;
  }

  .panel-hdr {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.1rem;
    font-size: 0.6rem;
    font-family: var(--font-code);
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    opacity: 0.3;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 7%, transparent);
    background: color-mix(in srgb, var(--text) 2%, transparent);
  }

  .ctrl {
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 6%, transparent);
  }
  .ctrl:last-child {
    border-bottom: none;
  }

  .ctrl-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ctrl-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.35;
    margin-bottom: 0.55rem;
  }
  .ctrl-row .ctrl-hd {
    margin: 0;
  }

  /* Type chips */
  .type-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.28rem;
  }

  .type-chip {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.36rem 0.48rem;
    border-radius: 7px;
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    transition:
      background 0.12s,
      border-color 0.12s;
  }
  .type-chip:hover {
    background: color-mix(in srgb, var(--cc) 8%, transparent);
    border-color: color-mix(in srgb, var(--cc) 20%, transparent);
  }
  .type-chip--on {
    background: color-mix(in srgb, var(--cc) 12%, transparent);
    border-color: color-mix(in srgb, var(--cc) 30%, transparent);
  }
  .chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cc);
    flex-shrink: 0;
    opacity: 0.45;
    transition: opacity 0.12s;
  }
  .type-chip--on .chip-dot {
    opacity: 1;
  }
  .chip-txt {
    font-family: var(--font-code);
    font-size: 0.57rem;
    opacity: 0.38;
    transition:
      opacity 0.12s,
      color 0.12s;
  }
  .type-chip--on .chip-txt {
    opacity: 1;
    color: var(--cc);
  }

  /* Variant pills */
  .variant-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.26rem;
  }

  .v-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem 0.1rem;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--text) 9%, transparent);
    font-family: var(--font-code);
    font-size: 0.55rem;
    opacity: 0.38;
    cursor: pointer;
    text-align: center;
    transition:
      background 0.12s,
      border-color 0.12s,
      opacity 0.12s;
  }
  .v-pill:hover {
    opacity: 0.72;
    background: color-mix(in srgb, var(--text) 5%, transparent);
  }
  .v-pill--on {
    opacity: 1;
    background: color-mix(in srgb, var(--text) 10%, transparent);
    border-color: color-mix(in srgb, var(--text) 30%, transparent);
    color: var(--text);
    font-weight: 700;
  }

  /* Message */
  .inp-wrap {
    position: relative;
  }
  .msg-inp {
    width: 100%;
    box-sizing: border-box;
    background: color-mix(in srgb, var(--text) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    border-radius: 8px;
    padding: 0.46rem 2.3rem 0.46rem 0.68rem;
    font-family: var(--font-main);
    font-size: 0.75rem;
    color: var(--text);
    outline: none;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }
  .msg-inp:focus {
    border-color: color-mix(in srgb, var(--brand) 45%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 8%, transparent);
  }
  .char-ct {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.55rem;
    font-family: var(--font-code);
    opacity: 0.22;
    pointer-events: none;
  }

  /* Range */
  .range-sl {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    border-radius: 99px;
    background: color-mix(in srgb, var(--text) 12%, transparent);
    outline: none;
    cursor: pointer;
    display: block;
  }
  .range-sl::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--text);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--text) 26%, transparent);
    cursor: pointer;
  }
  .range-tks {
    display: flex;
    justify-content: space-between;
    font-size: 0.53rem;
    font-family: var(--font-code);
    opacity: 0.2;
    margin-top: 0.26rem;
  }

  /* Toggle */
  .toggle {
    width: 34px;
    height: 19px;
    border-radius: 99px;
    background: color-mix(in srgb, var(--text) 40%, transparent);
    border: none;
    cursor: pointer;
    position: relative;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .toggle--off {
    background: color-mix(in srgb, var(--text) 15%, transparent);
  }
  .tg-thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .toggle[aria-checked="true"] .tg-thumb {
    transform: translateX(15px);
  }
  .toggle[aria-checked="false"] .tg-thumb {
    transform: translateX(0);
  }

  /* Fire */
  .fire-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    width: 100%;
    padding: 0.52rem;
    border: none;
    border-radius: 9px;
    background: var(--brand);
    color: #fff;
