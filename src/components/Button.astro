---
export interface Props {
  variant?: "primary" | "outline";
  type?: "button" | "submit" | "reset";
  href?: string;
  newTab?: boolean;
  [key: string]: any;
}

const {
  variant = "primary",
  type = "button",
  href,
  newTab = false,
  ...rest
} = Astro.props;
---

{
  href ? (
    <a
      href={href}
      target={newTab ? "_blank" : undefined}
      rel={newTab ? "noopener noreferrer" : undefined}
      class={`btn btn-${variant}`}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button type={type} class={`btn btn-${variant}`} {...rest}>
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 150px;
    padding: 0.5rem 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    text-decoration: none;
    color: inherit;
    font-family: inherit;
    border: none;
  }

  .btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.2);
  }

  .btn-primary {
    background: black;
    color: white;
  }

  .btn-primary:hover {
    background: #1f1f1f;
  }

  .btn-outline {
    background: transparent;
    border: 1px solid #d4d4d4;
    color: inherit;
  }

  .btn-outline:hover {
    background: #f5f5f5;
  }

  :global(.dark) .btn-primary {
    background: white;
    color: black;
  }

  :global(.dark) .btn-primary:hover {
    background: #e5e5e5;
  }

  :global(.dark) .btn-outline {
    border-color: #404040;
  }

  :global(.dark) .btn-outline:hover {
    background: #1f1f1f;
  }
</style>
