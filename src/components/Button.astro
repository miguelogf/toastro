---
export interface Props {
  variant?: "primary" | "outline" | "ghost";
  type?: "button" | "submit" | "reset";
  href?: string;
  newTab?: boolean;
  fullWidth?: boolean;
  [key: string]: any;
}

const {
  variant = "primary",
  type = "button",
  href,
  newTab = false,
  fullWidth = false,
  ...rest
} = Astro.props;
---

{
  href ? (
    <a
      href={href}
      target={newTab ? "_blank" : undefined}
      rel={newTab ? "noopener noreferrer" : undefined}
      class={`btn btn-${variant} ${fullWidth ? "full-width" : ""}`}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={`btn btn-${variant} ${fullWidth ? "full-width" : ""}`}
      {...rest}
    >
      <slot />
    </button>
  )
}

<style>
  .btn {
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 0.4rem 1.5rem;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-main);
    border-radius: var(--radius);
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease,
      opacity 0.2s ease;
  }

  .btn:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
  }

  .btn:active {
    transform: scale(0.97);
  }

  /* ── PRIMARY: fondo sólido con --text, invertido ── */
  .btn-primary {
    background-color: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }
  .btn-primary:hover {
    background-color: color-mix(in srgb, var(--text) 85%, var(--bg));
    border-color: color-mix(in srgb, var(--text) 85%, var(--bg));
    transform: scale(1.03);
  }

  /* ── OUTLINE: borde visible, fondo transparente ── */
  .btn-outline {
    background-color: transparent;
    color: var(--text);
    border: 1px solid color-mix(in srgb, var(--text) 25%, transparent);
  }
  .btn-outline:hover {
    background-color: color-mix(in srgb, var(--text) 6%, transparent);
    border-color: color-mix(in srgb, var(--text) 40%, transparent);
    transform: scale(1.03);
  }

  /* ── GHOST: sin borde ni fondo, solo hover sutil ── */
  .btn-ghost {
    background-color: transparent;
    color: var(--text);
    border: 1px solid transparent;
  }
  .btn-ghost:hover {
    background-color: color-mix(in srgb, var(--text) 6%, transparent);
    transform: scale(1.03);
  }

  /* ── Full width solo en mobile ── */
  @media (max-width: 640px) {
    .btn.full-width {
      width: 100%;
      min-width: 0;
      padding: 0.6rem 1.5rem;
    }
  }
</style>
