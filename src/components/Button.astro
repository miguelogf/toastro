---
export interface Props {
  variant?: "primary" | "outline" | "ghost";
  type?: "button" | "submit" | "reset";
  href?: string;
  newTab?: boolean;
  fullWidth?: boolean;
  color?: string;
  textColor?: string;
  [key: string]: any;
}

const {
  variant = "primary",
  type = "button",
  href,
  newTab = false,
  fullWidth = false,
  color,
  textColor,
  ...rest
} = Astro.props;

// Preparamos los fallbacks para las variables de CSS
const accentColor = color || "var(--text)";
const customTextColor = textColor || (variant === "primary" ? "var(--bg)" : accentColor);
---

{
  href ? (
    <a
      href={href}
      target={newTab ? "_blank" : undefined}
      rel={newTab ? "noopener noreferrer" : undefined}
      class:list={["btn", `btn-${variant}`, { "full-width": fullWidth }]}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class:list={["btn", `btn-${variant}`, { "full-width": fullWidth }]}
      {...rest}
    >
      <slot />
    </button>
  )
}

<style define:vars={{ accentColor, customTextColor }}>
  .btn {
    --accent: var(--accentColor);
    --btn-text: var(--customTextColor);
    
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.5rem;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius, 8px);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    color: var(--btn-text);
    margin-bottom: 1rem;
  }

  .btn-primary {
    background-color: var(--accent);
    border: 1px solid var(--accent);
    color: var(--btn-text);
  }

  .btn-outline {
    background-color: color-mix(in srgb, var(--accent) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
  }

  .btn-ghost {
    background-color: transparent;
    border: 1px solid transparent !important;
    color: var(--accent);
    padding: 0.5rem 0.5rem;
    opacity: 0.5;
  }

  /* --- Estados --- */
  .btn:hover {
    opacity: 0.9;
    transform: scale(1.03);
  }

  .btn-ghost:hover {
    background-color: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .btn:active {
    transform: scale(0.96) !important;
  }

  .btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .btn.full-width {
      width: 100%;
      min-width: 0;
    }
  }
</style>