---
import Badge from "../components/Badge.astro";
import ToastContainer from "../components/ToastContainer.astro";
import logoLight from "../assets/logo-light.svg";
import logoDark from "../assets/logo-dark.svg";
import Button from "../components/Button.astro";
import { ICONS } from "../utils/icons";
---

<section class="hero">
  <div class="hero-content">
    <Badge
      label="Coming Soon"
      variant="gradient"
      color="var(--accent-color)"
      gradientColors={["#f97316", "#f31b75"]}
    />
    <div class="logo-container">
      <div class="logo-wrapper">
        <img src={logoDark.src} alt="Logo" class="logo-dark" />
        <img src={logoLight.src} alt="Logo" class="logo-light" />
      </div>
        
      <h1 class="logo-text">
        
        toast<span class="text-gradient-toastro">ro</span>
      </h1>
    </div>
    <h2 class="description">
      A beautiful and minimal<br />
      <span class="text-gradient-orange">toast</span> for
      <span class="text-gradient-pink">Astro.</span>
    </h2>
    <div class="buttons">
    <Button id="btn-toast" >Toast me! ✨</Button>
    <Button href="https://github.com/miguelogf/toastro/tree/main" variant="outline" newTab>Documentation</Button>
    </div>
    <script>
import { ICONS } from "../utils/icons";

    document.addEventListener("DOMContentLoaded", () => {
      const btn = document.getElementById("btn-toast");
      
      // 1. Pool de opciones usando TUS clases de global.css
      const toastOptions = [
        { 
          message: "Lorem Ipsum is simply dummy text of the printing and typesetting industry.", 
          type: "warning",
          icon: ICONS.sparkles,
          variant: "glass", 
        },
        { 
          message: "Successfully deployed to Vercel", 
          type: "success", 
          variant: "solid", 
        },
        {
          message: "Warning: Low disk space",
          type: "warning",
          variant: "soft",
        },
        
        { 
          message: "Thanks for the support!",
          type: "support",
          variant: "outline", 
        },
        {
            message: "New update available",
            type: "loading", 
            variant: "solid", 
        },
        { 
          message: "🍞✨ A minimal toast for Astro", 
          icon: "", // Sin icono"",
          
          variant: "gradient",
          gradientColors: ["#6366f1", "#f31b75"],
        },

      ];
      if (btn) {
        btn.addEventListener("click", () => {
          // 2. Selección aleatoria
          const randomConfig = toastOptions[Math.floor(Math.random() * toastOptions.length)];
          
          // 3. Llamada a la función global (asegurando que existe)
          if (window.showToast) {
            window.showToast(randomConfig as any);
          }
        });
      }
    });
    </script>
  </div>
</section>

<ToastContainer />

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }  
  .logo-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem; /* espacio entre el logo y el texto */
    margin-top: -1.25rem;
  }
  /* 1. Lógica de visibilidad por defecto (Modo Claro) */
  .logo-dark {
    display: none !important;
  }
  .logo-light {
    display: block !important;
  }

  /* 2. Lógica para Modo Oscuro (Nativo del sistema) */
  html.dark .logo-light {
    display: none !important;
  }
  html.dark .logo-dark {
    display: block !important;
  }
  .logo-text {
    display: inline-flex;
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -1px;
    margin: 1rem 0;
  }
  .logo-wrapper {
    width: 2rem; /* ajusta el tamaño del icono */
    height: auto;
  }
  .description {
    font-size: 3rem;
    font-weight: 200;
    margin: 0;
    text-align: center; /* centra el texto */
  }

  .text-gradient-toastro {
    background: linear-gradient(to right, #f97316, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .text-gradient-orange {
    background: linear-gradient(to right, #f97316, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .text-gradient-pink {
    background: linear-gradient(to right, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
    /* Responsive - Tablet (768px y menores) */
  @media (max-width: 768px) {
    .hero {
      padding: 0 1.5rem;
      gap: 0.75rem;
    }

    .description {
      font-size: 2.5rem;
      padding: 0 0.75rem;
    }
  }

  /* Responsive - Móvil (480px y menores) */
  @media (max-width: 480px) {
    .hero {
      padding: 0 1rem;
      gap: 0.5rem;
    }

    .logo-text {
      font-size: 2.5rem;
    }

    .logo-text img {
      width: 2rem;
    }

    .description {
      font-size: 1.75rem;
      padding: 0 0.5rem;
    }
</style>
