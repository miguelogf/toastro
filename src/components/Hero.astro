---
import Badge from "../components/Badge.astro";
import ToastContainer from "../components/ToastContainer.astro";
import logoLight from "../assets/logo-light.svg";
import logoDark from "../assets/logo-dark.svg";
import Button from "../components/Button.astro";
import { ICONS } from "../utils/icons.ts";
---

<section class="hero">
  <div class="hero-content">
    <Badge
      label="Coming Soon"
      variant="gradient"
      color="var(--accent-color)"
      gradientColors={["#f97316", "#f31b75"]}
    />

    <div class="logo-container" aria-hidden="true">
      <div class="logo-wrapper">
        <img src={logoDark.src} alt="" class="logo-dark" />
        <img src={logoLight.src} alt="" class="logo-light" />
      </div>
      <span class="logo-text"
        >toast<span class="text-gradient-toastro">ro</span></span
      >
    </div>

    <h1 class="hero-title">
      A beautiful and minimal<br />
      <span class="text-gradient-orange">toast</span> for
      <span class="text-gradient-pink">Astro.</span>
    </h1>

    <div class="buttons">
      <Button id="btn-toast">Toast me! ✨</Button>
      <Button
        href="https://github.com/miguelogf/toastro"
        variant="outline"
        newTab
      >
        Documentation
      </Button>
    </div>
  </div>
</section>

<ToastContainer />

<script>
  import { ICONS } from "../utils/icons";

  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("btn-toast");

    const toastOptions = [
      {
        message:
          "Lorem Ipsum is simply dummy text of the printing and typesetting industry.",
        type: "warning",
        icon: ICONS.sparkles,
        variant: "glass",
      },
      {
        message: "Successfully deployed to Vercel",
        type: "success",
        variant: "default",
      },
      {
        message: "Warning: Low disk space",
        type: "warning",
        variant: "soft",
      },
      {
        message: "Thanks for the support!",
        type: "vibrant",
        variant: "outline",
      },
      {
        message: "New update available",
        type: "neutral",
        variant: "solid",
      },
      {
        message: "🍞✨ A minimal toast for Astro",
        icon: "", // Sin icono"",
        variant: "gradient",
        gradientColors: ["#6366f1", "#f31b75"],
      },
    ];

    btn?.addEventListener("click", () => {
      const randomConfig =
        toastOptions[Math.floor(Math.random() * toastOptions.length)];
      window.showToast?.(randomConfig as any);
    });
  });
</script>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 1rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 800px; /* Evita que el texto se vea muy largo en monitores grandes */
    margin: 0 auto;
    gap: 1.5rem;
  }

  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    margin-top: -0.75rem;
  }

  .logo-wrapper {
    width: 2.5rem;
    aspect-ratio: 1 / 1;
  }

  .logo-text {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -1px;
  }

  .logo-dark {
    display: none;
  }
  html.dark .logo-dark {
    display: block;
  }
  html.dark .logo-light {
    display: none;
  }

  .hero-title {
    font-size: clamp(2rem, 8vw, 3.5rem); /* Tamaño fluido según pantalla */
    font-weight: 200;
    margin: 0;
    line-height: 1.1;
    text-wrap: nowrap;
  }

  /* GRADIENTES */
  .text-gradient-toastro {
    background: linear-gradient(to right, #f97316, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .text-gradient-orange {
    background: linear-gradient(to right, #f97316, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .text-gradient-pink {
    background: linear-gradient(to right, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.25rem;
      text-wrap: nowrap;
    }

    .buttons {
      flex-direction: column;
      align-items: center; /*stretch: Estira los botones al mismo ancho*/
      gap: 0.8rem;
      padding: 0 1rem;
    }

    .buttons > :global(.btn) {
      width: 85% !important;
      min-width: none;
    }

    .logo-text {
      font-size: 2.5rem;
    }
  }
</style>
