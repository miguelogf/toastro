---
import Badge from "../components/Badge.astro";
import ToastContainer from "../components/ToastContainer.astro";
import "../styles/theme.css";
import logoLight from "../assets/logo-light.svg";
import logoDark from "../assets/logo-dark.svg";
import Button from "../components/Button.astro";
---

<div id="container">
  <main class="text-center">
    <section class="hero">
      <Badge
        label="Coming Soon"
        variant="gradient"
        color="var(--accent-toast)"
        gradientColors={["#f97316", "#f31b75"]}
      />
      <div class="logo-container">
        <div class="logo-wrapper">
          <img src={logoDark.src} alt="Logo" class="logo-dark" />
          <img src={logoLight.src} alt="Logo" class="logo-light" />
        </div>
          
        <h1 class="logo-text">
          
          toast<span class="text-gradient-toastro">ro</span>
        </h1>
      </div>
      <h2 class="description">
        A beautiful and minimal<br />
        <span class="text-gradient-orange">toast</span> for
        <span class="text-gradient-pink">Astro.</span>
      </h2>
      <div class="buttons">
      <Button id="btn-toast" >Toast me! ✨</Button>
      <Button href="https://github.com/miguelogf/toastro/tree/main" variant="outline" newTab>Documentation</Button>
      </div>
      <script>
      document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("btn-toast");
        
        // 1. Pool de opciones usando TUS clases de global.css
        const toastOptions = [
          { 
            message: "Lorem Ipsum is simply dummy text of the printing and typesetting industry.", 
            type: "warning",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles-icon lucide-sparkles"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/><path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/></svg>`,
            variant: "glass", 
          },
          { 
            message: "Successfully deployed to Vercel", 
            type: "success", 
            variant: "solid", 
          },
          {
            message: "Warning: Low disk space",
            type: "warning",
            variant: "soft",
          },
          
          { 
            message: "Thanks for the support!",
            type: "accent",
            variant: "outline", 
          },
          {
              message: "New update available",
              type: "loading", 
              variant: "filled", 
          },
          { 
            message: "🍞✨ A minimal toast for Astro", 
            type: "accent", 
            icon: "", // Sin icono"",
            
            variant: "gradient",
            gradientColors: ["#6366f1", "#f31b75"],
          },

        ];
        if (btn) {
          btn.addEventListener("click", () => {
            // 2. Selección aleatoria
            const randomConfig = toastOptions[Math.floor(Math.random() * toastOptions.length)];
            
            // 3. Llamada a la función global (asegurando que existe)
            if (window.showToast) {
              window.showToast(randomConfig as any);
            }
          });
        }
      });
        </script>
      </section>
      <!-- <section id="install">
        <h2>Quick Start: Install Toastro in 30 seconds</h2>
        <p>The most lightweight <strong>Astro toast library</strong> for your next project.</p>
        
        <div class="code-block">
          <pre><code>npm install toastro</code></pre>
          <button onclick="copyToClipboard('npm install toastro')">Copy</button>
        </div>
      </section> -->
    </main>
  </div>

<ToastContainer />



<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center; /* centra horizontalmente */
    justify-content: center; /* centra verticalmente (opcional) */
  }
  
  .logo-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: .5rem; /* espacio entre el logo y el texto */
    
    
  }
  /* 1. Lógica de visibilidad por defecto (Modo Claro) */
  .logo-dark {
    display: none !important;
  }
  .logo-light {
    display: block !important;
  }

  /* 2. Lógica para Modo Oscuro (Nativo del sistema) */
  html.dark  {
    .logo-light {
      display: none !important;
    }
    .logo-dark {
      display: block !important;
    }
  }
  .logo-text {
    display: inline-flex;
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -1px;
    margin: 1rem 0;
  }
  .logo-wrapper {
    width: 2rem; /* ajusta el tamaño del icono */
    height: auto;
  }
  .description {
    font-size: 3rem;
    font-weight: 200;
    margin: 0;
    text-align: center; /* centra el texto */
  }

  .text-gradient-toastro {
    background: linear-gradient(to right, #f97316, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .text-gradient-orange {
    background: linear-gradient(to right, #f97316, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .text-gradient-pink {
    background: linear-gradient(to right, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
    /* Responsive - Tablet (768px y menores) */
  @media (max-width: 768px) {
    .hero {
      padding: 0 1.5rem;
      gap: 0.75rem;
    }

    .description {
      font-size: 2.5rem;
      padding: 0 0.75rem;
    }
  }

  /* Responsive - Móvil (480px y menores) */
  @media (max-width: 480px) {
    .hero {
      padding: 0 1rem;
      gap: 0.5rem;
    }

    .logo-text {
      font-size: 2.5rem;
    }

    .logo-text img {
      width: 2rem;
    }

    .description {
      font-size: 1.75rem;
      padding: 0 0.5rem;
    }
</style>
