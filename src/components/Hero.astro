---
import Badge from "../components/Badge.astro";
import ToastContainer from "../components/ToastContainer.astro";
import Button from "../components/Button.astro";
import Icon from "./Icon.astro";
---

<section class="hero">
  <div class="hero-content">
    <Badge
      variant="gradient"
      color="var(--brand)"
      class="badge-hero"
      animate="fade"
      gradientColors={["#f97316", "#f31b75"]}
    >
      <span class="badge-dot"></span>Open Source · MIT Licensed</Badge
    >
    <h1 class="hero-title">
      A beautiful and minimal
      <span translate="no" class="text-gradient-orange">toast</span>
      for
      <span class="text-gradient-pink">Astro.</span>
    </h1>
    <div class="buttons">
      <Button translate="no" id="btn-toast" fullWidth
        >Toast me! <Icon name="bell" /></Button
      >
      <Button
        href="https://github.com/miguelogf/toastro"
        variant="outline"
        newTab
        fullWidth
      >
        Star on GitHub <Icon name="github" />
      </Button>
    </div>
  </div>
</section>

<ToastContainer />

<script>
  import { ICONS } from "../utils/icons.ts";
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("btn-toast");

    const toastOptions = [
      {
        message:
          "Lorem Ipsum is simply dummy text of the printing and typesetting industry.",
        type: "warning",
        icon: ICONS["sparkles"],
        variant: "glass",
      },
      {
        message: "Successfully deployed to Vercel",
        type: "success",
        variant: "default",
      },
      {
        message: "Warning: Low disk space",
        type: "warning",
        variant: "soft",
      },
      {
        message: "Thanks for the support!",
        type: "vibrant",
        variant: "outline",
      },
      {
        message: "New update available",
        type: "neutral",
        variant: "solid",
      },
      {
        message: "🍞✨ A minimal toast for Astro",
        icon: "", // Sin icono"",
        variant: "gradient",
        gradientColors: ["#6366f1", "#f31b75"],
      },
    ];

    btn?.addEventListener("click", () => {
      const randomConfig =
        toastOptions[Math.floor(Math.random() * toastOptions.length)];
      window.showToast?.(randomConfig as any);
    });
  });
</script>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 1rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    gap: 1.75rem;
  }

  .hero-title {
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-wrap: balance;
    max-width: 20ch;
    margin: 0 auto;
    text-align: center;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand);
    animation: pulse 2s ease infinite;
  }
  /* GRADIENTES */
  .text-gradient-orange {
    background: linear-gradient(to right, #f97316, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .text-gradient-pink {
    background: linear-gradient(to right, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    justify-content: center;
    width: 100%;
  }

  #btn-toast {
    gap: 0.25rem;
  }
  @media (max-width: 640px) {
    .logo-wrapper {
      width: 2rem;
    }

    .logo-text {
      font-size: 2.5rem;
    }

    .hero-title {
      text-wrap: balance;
      max-width: 20ch;
    }

    .buttons {
      flex-direction: column;
      width: 95%;
      margin: 2rem auto 0 auto;
    }
  }
</style>
