---
import Logo from "../components/Logo.astro";
import Badge from "./Badge.astro";
import IconLink from "./IconLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

const iconLinks = [
  { name: "github", href: "https://github.com/miguelogf" },
  { name: "linkedin", href: "https://www.linkedin.com/in/miguelogf/" },
  { name: "x", href: "https://x.com/_miguelogf" },
] as const;
---

<nav class="navbar">
  <div class="navbar-container">
    <div class="navbar-brand">
      <a href="/"><Logo /></a>
      <Badge
        variant="soft"
        color="var(--status-error)"
        animate="bounce"
        class="badge--sm">v0.1.0</Badge
      >
    </div>

    <div class="navbar-menu" id="navMenu">
      <div class="nav-links">
        <a href="/" class="nav-link">Home</a>
        <a href="/docs" class="nav-link">Docs</a>
        <a href="/changelog" class="nav-link">Changelog</a>
      </div>

      <div class="mobile-links">
        {
          iconLinks.map((link) => (
            <IconLink name={link.name} href={link.href} />
          ))
        }
      </div>
    </div>

    <div class="navbar-actions">
      <div class="desktop-links">
        {
          iconLinks.map((link) => (
            <IconLink name={link.name} href={link.href} />
          ))
        }
      </div>
      <div class="spacer"></div>
      <ThemeToggle />
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span class="line top"></span>
        <span class="line bottom"></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById("menuToggle");
  const navMenu = document.getElementById("navMenu");
  const body = document.body;

  menuToggle?.addEventListener("click", () => {
    const isOpened = menuToggle.classList.toggle("is-active");
    navMenu?.classList.toggle("is-visible");

    // Evita el scroll cuando el menú está abierto
    body.style.overflow = isOpened ? "hidden" : "";
  });
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    transition: color 0.75s ease;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 5%, transparent);
    padding: 0.75rem 1.5rem;
  }

  .navbar::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--bg) 75%, transparent);
    backdrop-filter: blur(1rem);
    -webkit-backdrop-filter: blur(1rem);
    transition: background-color 0.75s ease;
  }

  .navbar-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Desktop Menu */
  .navbar-brand {
    justify-self: start;
    display: flex;
    gap: 0.25rem;
  }

  .navbar-menu {
    justify-self: center;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }
  .nav-link {
    text-decoration: none;
    color: var(--text);
    font-weight: 400;
    font-size: 0.9rem;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .nav-link:hover {
    opacity: 1;
  }
  .navbar-actions {
    justify-self: end;
    display: flex;
    flex-direction: row !important;
    align-items: center;
    gap: 1rem;
  }
  .desktop-links {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }
  .spacer {
    width: 1px;
    height: 1.5rem;
    background: var(--text);
    opacity: 0.2;
  }

  /* Hamburguesa: El arte de las 2 líneas */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px; /* Espacio entre las 2 líneas */
    width: 2rem;
    height: 2rem;
    background: none;
    border: 1px transparent;
    border-radius: 8px;
    cursor: pointer;
    z-index: 101;
    padding: 0;
  }

  .menu-toggle:hover {
    background: rgba(128, 128, 128, 0.2);
  }

  .line {
    width: 22px;
    height: 1.5px;
    background-color: var(--text);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Animación de la X sin deformación */
  .menu-toggle.is-active .line.top {
    /* 3.75px es el cálculo mágico: (6px gap + 1.5px height) / 2 */
    transform: translateY(3.75px) rotate(45deg);
  }

  .menu-toggle.is-active .line.bottom {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* Responsive Logic */
  @media (min-width: 769px) {
    .mobile-links {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .navbar-container {
      grid-template-columns: auto 1fr;
    }
    .menu-toggle {
      display: flex;
    }
    .desktop-links,
    .spacer {
      display: none;
    }
    .navbar-menu {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100dvh;
      background: color-mix(in srgb, var(--bg) 75%, transparent);
      backdrop-filter: blur(1.5rem);
      -webkit-backdrop-filter: blur(1.5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 3rem;
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0.5s;
      z-index: 100;
    }
    .navbar-menu.is-visible {
      opacity: 1;
      visibility: visible;
    }
    .nav-links {
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
    }
    .nav-link {
      font-size: 1.5rem;
      font-weight: 300;
      transform: translateY(15px);
      opacity: 0;
      transition:
        transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
        opacity 0.4s ease;
    }
    /* Cuando el menú se abre */
    .navbar-menu.is-visible .nav-link {
      transform: translateY(0);
      opacity: 0.7;
    }
    .navbar-menu.is-visible .nav-link:hover {
      opacity: 1;
    }
    /* Efecto escalonado (Stagger) */
    .nav-link:nth-child(1) {
      transition-delay: 0.1s;
    }
    .nav-link:nth-child(2) {
      transition-delay: 0.2s;
    }
    .nav-link:nth-child(3) {
      transition-delay: 0.3s;
    }
    .mobile-links {
      display: flex;
      gap: 2rem;
      margin-top: 1rem;
    }
  }
</style>
