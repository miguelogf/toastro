---
import ThemeToggle from "./ThemeToggle.astro";
import SocialLink from "./SocialLink.astro";
import logo from "../assets/logo.svg";
import type { BRANDS } from "../utils/brands";

// Tipado correcto para TypeScript
const socialLinks: { name: keyof typeof BRANDS; href: string }[] = [
  { name: "github", href: "https://github.com/miguelogf" },
  { name: "linkedin", href: "https://www.linkedin.com/in/miguelogf/" },
  { name: "x", href: "https://x.com/_miguelogf" },
];
---

<nav class="navbar">
  <div class="navbar-left">
    <img src={logo.src} alt="My Brand Logo" class="logo" />
  </div>

  <div class="navbar-center">
    <a href="/about" class="nav-link">About</a>
    <a href="/docs" class="nav-link">Docs</a>
    <a href="/changelog" class="nav-link">Changelog</a>
  </div>

  <div class="navbar-right">
    <div class="social-links">
      {
        socialLinks.map((link) => (
          <SocialLink name={link.name} href={link.href} />
        ))
      }
    </div>

    <div class="spacer"></div>

    <ThemeToggle />
  </div>
</nav>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar-left .logo {
    height: 2rem;
    width: auto;
  }

  /* Centro siempre centrado */
  .navbar-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    text-decoration: none;
    color: inherit;
    font-weight: 300;
    transition: color 0.2s ease;
    opacity: 0;
  }

  .nav-link:hover {
    color: var(--accent-color);
  }

  .navbar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .social-links a:hover {
    background: rgba(128, 128, 128, 0.1);
    transform: scale(1.1);
    opacity: 0.7;
  }

  .spacer {
    width: 1px;
    background: gray;
    height: 24px;
    opacity: 0.5;
  }
</style>
