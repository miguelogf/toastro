---
import Logo from "../components/Logo.astro";
import Badge from "./Badge.astro";
import IconLink from "./IconLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

const iconLinks = [
  { name: "github", href: "https://github.com/miguelogf" },
  { name: "linkedin", href: "https://www.linkedin.com/in/miguelogf/" },
  { name: "x", href: "https://x.com/_miguelogf" },
] as const;

const navLinks = [
  { label: "Home", href: "/", index: "01" },
  { label: "Docs", href: "/docs", index: "02" },
  { label: "Changelog", href: "/changelog", index: "03" },
] as const;

const currentPath = Astro.url.pathname;
---

<!-- transition:persist keeps navbar alive across View Transitions page changes -->
<nav class="navbar" id="navbar" transition:persist>
  <div class="navbar-container">
    <div class="navbar-brand">
      <a href="/"><Logo /></a>
      <Badge variant="soft" animate="bounce" class="badge--sm"> v0.1.0 </Badge>
    </div>

    <div class="navbar-menu" id="navMenu">
      <div class="nav-links">
        {
          navLinks.map(({ label, href, index }) => {
            const isActive =
              currentPath === href ||
              (href !== "/" && currentPath.startsWith(href));
            return (
              <a
                href={href}
                class:list={["nav-link", isActive && "nav-link--active"]}
              >
                <span class="nl-index">{index}</span>
                <span class="nl-label">{label}</span>
                <svg
                  class="nl-arrow"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  width="16"
                  height="16"
                >
                  <path d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            );
          })
        }
      </div>

      <!-- Mobile-only: socials inside the overlay -->
      <div class="mobile-links">
        {
          iconLinks.map((link) => (
            <IconLink name={link.name} href={link.href} />
          ))
        }
      </div>
    </div>

    <div class="navbar-actions">
      <div class="desktop-links">
        {
          iconLinks.map((link) => (
            <IconLink name={link.name} href={link.href} />
          ))
        }
      </div>
      <div class="spacer"></div>
      <ThemeToggle />
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span class="line top"></span>
        <span class="line bottom"></span>
      </button>
    </div>
  </div>
</nav>

<script>
  function initNavbar() {
    const menuToggle = document.getElementById("menuToggle");
    const navMenu = document.getElementById("navMenu");
    const body = document.body;

    if (!menuToggle || !navMenu) return;

    // Remove old listeners by cloning (safe for re-init after astro:after-swap)
    const newToggle = menuToggle.cloneNode(true) as HTMLElement;
    menuToggle.parentNode?.replaceChild(newToggle, menuToggle);

    newToggle.addEventListener("click", () => {
      const isOpened = newToggle.classList.toggle("is-active");
      navMenu.classList.toggle("is-visible");
      body.style.overflow = isOpened ? "hidden" : "";
    });

    // Close menu on mobile link click (after navigation)
    navMenu.querySelectorAll(".nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        newToggle.classList.remove("is-active");
        navMenu.classList.remove("is-visible");
        body.style.overflow = "";
      });
    });
  }

  // Initial load
  initNavbar();
  // Re-init after each View Transition swap (navbar is persisted, but scripts re-run)
  document.addEventListener("astro:after-swap", initNavbar);
</script>

<style>
  /* ── Navbar ── */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    transition: color 0.75s ease;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 5%, transparent);
    padding: 0.75rem 1.5rem;
  }

  .navbar::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--bg) 75%, transparent);
    backdrop-filter: blur(1rem);
    -webkit-backdrop-filter: blur(1rem);
    transition: background-color 0.75s ease;
  }

  .navbar-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Brand ── */
  .navbar-brand {
    justify-self: start;
    display: flex;
    gap: 0.25rem;
  }

  /* ── Desktop nav links ── */
  .navbar-menu {
    justify-self: center;
    animation: fadeUp 0.6s ease both;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  .nav-link {
    text-decoration: none;
    color: var(--text);
    font-weight: 400;
    font-size: 0.9rem;
    opacity: 0.5;
    transition: opacity 0.2s;
    position: relative;
  }

  /* Hide mobile-only elements on desktop */
  .nl-index,
  .nl-arrow {
    display: none;
  }

  .nav-link:hover {
    opacity: 1;
  }

  /* Active: just a subtle brand dot underneath — no background */
  .nav-link--active {
    opacity: 1;
    /*color: var(--brand);*/
  }

  .nav-link--active::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--brand);
    animation: dot-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes dot-in {
    from {
      transform: translateX(-50%) scale(0);
      opacity: 0;
    }
    to {
      transform: translateX(-50%) scale(1);
      opacity: 1;
    }
  }

  /* ── Actions ── */
  .navbar-actions {
    justify-self: end;
    display: flex;
    flex-direction: row !important;
    align-items: center;
    gap: 1rem;
  }

  .desktop-links {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }

  .spacer {
    width: 1px;
    height: 1.5rem;
    background: var(--text);
    opacity: 0.2;
  }

  /* ── Hamburger (original span approach — it works) ───── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    z-index: 101;
    padding: 0;
  }

  .menu-toggle:hover {
    background: rgba(128, 128, 128, 0.15);
  }

  .line {
    width: 22px;
    height: 1.5px;
    background-color: var(--text);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 3.75px = (6px gap + 1.5px height) / 2 — sin deformación */
  .menu-toggle.is-active .line.top {
    transform: translateY(3.75px) rotate(45deg);
  }
  .menu-toggle.is-active .line.bottom {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* ── Mobile overlay ── */
  @media (min-width: 769px) {
    .mobile-links {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .navbar-container {
      grid-template-columns: auto 1fr;
    }

    .menu-toggle {
      display: flex;
    }
    .desktop-links {
      display: none;
    }
    .spacer {
      display: none;
    }

    .navbar-menu {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100dvh;
      background: color-mix(in srgb, var(--bg) 82%, transparent);
      backdrop-filter: blur(24px) saturate(160%);
      -webkit-backdrop-filter: blur(24px) saturate(160%);

      /* Center everything */
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 3rem;

      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0.4s;
      z-index: 100;
    }

    .navbar-menu.is-visible {
      opacity: 1;
      visibility: visible;
    }

    /* ── Mobile nav links — editorial large type ── */
    .nav-links {
      flex-direction: column;
      align-items: center;
      gap: 0;
      width: 100%;
      max-width: 320px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      justify-content: start;
      gap: 0.85rem;
      width: 100%;
      padding: 0.9rem 0;
      border-bottom: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
      font-size: clamp(1.4rem, 6vw, 1.9rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
        transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
        color 0.2s;
    }

    /* Remove the dot on mobile */
    .nav-link::after {
      display: none;
    }

    .nl-index,
    .nl-arrow {
      display: flex;
    }

    .nl-index {
      font-family: var(--font-code);
      font-size: 0.62rem;
      font-weight: 500;
      opacity: 0.3;
      letter-spacing: 0.04em;
      width: 20px;
      flex-shrink: 0;
      margin-bottom: -2px; /* optical align with large text */
    }

    .nl-label {
      text-align: center;
    }

    .nl-arrow {
      opacity: 0;
      transform: translate(-5px, 5px);
      transition:
        opacity 0.2s ease,
        transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
      flex-shrink: 0;
      color: var(--brand);
    }

    .navbar-menu.is-visible .nav-link {
      opacity: 0.6;
      transform: translateY(0);
    }

    .navbar-menu.is-visible .nav-link:hover {
      opacity: 1;
    }
    .navbar-menu.is-visible .nav-link:hover .nl-arrow {
      opacity: 1;
      transform: translate(0, 0);
    }

    .navbar-menu.is-visible .nav-link--active {
      opacity: 1;
      font-weight: 600;
      /* color: var(--brand); */
    }

    .navbar-menu.is-visible .nav-link--active .nl-index {
      color: var(--brand);
      opacity: 0.6;
    }

    .navbar-menu.is-visible .nav-link--active .nl-arrow {
      opacity: 0.45;
      transform: translate(0, 0);
    }

    /* Stagger */
    .nav-link:nth-child(1) {
      transition-delay: 0.08s;
    }
    .nav-link:nth-child(2) {
      transition-delay: 0.15s;
    }
    .nav-link:nth-child(3) {
      transition-delay: 0.22s;
    }

    /* Socials row */
    .mobile-links {
      display: flex;
      gap: 2rem;
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.4s ease 0.28s,
        transform 0.4s ease 0.28s;
    }

    .navbar-menu.is-visible .mobile-links {
      opacity: 0.5;
      transform: translateY(0);
    }
  }
</style>
