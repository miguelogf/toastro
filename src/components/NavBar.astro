---
// src/components/Navbar.astro
import Logo from "../components/Logo.astro";
import Badge from "./Badge.astro";
import IconLink from "./IconLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { ViewTransitions } from "astro:transitions";

const iconLinks = [
  { name: "github",   href: "https://github.com/miguelogf" },
  { name: "linkedin", href: "https://www.linkedin.com/in/miguelogf/" },
  { name: "x",        href: "https://x.com/_miguelogf" },
] as const;

const navLinks = [
  { label: "Home",      href: "/",          index: "01" },
  { label: "Docs",      href: "/docs",       index: "02" },
  { label: "Changelog", href: "/changelog",  index: "03" },
] as const;

const currentPath = Astro.url.pathname;
---

<ViewTransitions />

<nav class="navbar" id="navbar" transition:persist>
  <div class="navbar-container">

    <!-- Brand -->
    <div class="navbar-brand">
      <a href="/" class="brand-link" transition:name="logo">
        <Logo />
      </a>
      <Badge variant="soft" color="var(--status-error)" animate="bounce" class="badge--sm">
        v0.1.0
      </Badge>
    </div>

    <!-- Desktop links (center) -->
    <div class="nav-links">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || (href !== "/" && currentPath.startsWith(href));
        return (
          <a href={href} class:list={["nav-link", isActive && "nav-link--active"]}>
            {label}
          </a>
        );
      })}
    </div>

    <!-- Actions -->
    <div class="navbar-actions">
      <div class="desktop-socials">
        {iconLinks.map((link) => <IconLink name={link.name} href={link.href} />)}
      </div>
      <span class="divider" aria-hidden="true"></span>
      <ThemeToggle />
      <button class="hamburger" id="menuToggle" aria-label="Toggle menu" aria-expanded="false">
        <svg class="icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
          <line class="h-top" x1="3" y1="7" x2="21" y2="7"/>
          <line class="h-bot" x1="3" y1="17" x2="21" y2="17"/>
        </svg>
      </button>
    </div>

  </div>
</nav>

<!-- Mobile overlay — separate from the nav for z-index stacking -->
<div class="mobile-overlay" id="mobileOverlay" aria-hidden="true">
  
  <!-- Decorative brand watermark -->
  <span class="overlay-watermark" aria-hidden="true">toastro</span>

  <!-- Main links -->
  <nav class="overlay-nav" aria-label="Mobile navigation">
    {navLinks.map(({ label, href, index }) => {
      const isActive = currentPath === href || (href !== "/" && currentPath.startsWith(href));
      return (
        <a
          href={href}
          class:list={["mobile-link", isActive && "mobile-link--active"]}
          data-index={index}
        >
          <span class="ml-index">{index}</span>
          <span class="ml-label">{label}</span>
          <svg class="ml-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>
      );
    })}
  </nav>

  <!-- Bottom row: socials + theme -->
  <div class="overlay-footer">
    <div class="overlay-socials">
      {iconLinks.map((link) => <IconLink name={link.name} href={link.href} />)}
    </div>
    <div class="overlay-brand-line">
      <span>🍞</span>
      <span>Zero deps. Pure Astro.</span>
    </div>
  </div>

</div>

<script>
  function initNavbar() {
    const toggle   = document.getElementById("menuToggle") as HTMLButtonElement | null;
    const overlay  = document.getElementById("mobileOverlay") as HTMLElement | null;
    const navbar   = document.getElementById("navbar") as HTMLElement | null;
    const body     = document.body;

    if (!toggle || !overlay) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      overlay.classList.add("is-open");
      toggle!.classList.add("is-active");
      toggle!.setAttribute("aria-expanded", "true");
      body.style.overflow = "hidden";
    }

    function closeMenu() {
      isOpen = false;
      overlay.classList.remove("is-open");
      toggle!.classList.remove("is-active");
      toggle!.setAttribute("aria-expanded", "false");
      body.style.overflow = "";
    }

    toggle.addEventListener("click", () => {
      isOpen ? closeMenu() : openMenu();
    });

    // Close on overlay link click
    overlay.querySelectorAll(".mobile-link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) closeMenu();
    });

    // Scrolled state for navbar shadow
    const onScroll = () => {
      navbar?.classList.toggle("is-scrolled", window.scrollY > 12);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Run on first load and after each View Transition
  initNavbar();
  document.addEventListener("astro:after-swap", initNavbar);
</script>

<style>
  /* ── Navbar ──────────────────────────────────────────── */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 200;
    padding: 0 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 5%, transparent);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .navbar::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    transition: background 0.75s ease;
  }

  .navbar.is-scrolled {
    box-shadow: 0 1px 24px color-mix(in srgb, var(--text) 5%, transparent);
  }

  .navbar-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    height: 60px;
  }

  /* ── Brand ───────────────────────────────────────────── */
  .navbar-brand {
    justify-self: start;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .brand-link { display: flex; align-items: center; }

  /* ── Desktop nav links ───────────────────────────────── */
  .nav-links {
    justify-self: center;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    position: relative;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s, background 0.2s;
  }

  .nav-link:hover { opacity: 0.85; background: color-mix(in srgb, var(--text) 5%, transparent); }

  .nav-link--active {
    opacity: 1;
    background: color-mix(in srgb, var(--brand) 8%, transparent);
    color: var(--brand);
  }

  /* Animated underline on active */
  .nav-link--active::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 2px;
    border-radius: 99px;
    background: var(--brand);
    animation: dot-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes dot-in {
    from { width: 0; opacity: 0; }
    to   { width: 16px; opacity: 1; }
  }

  /* ── Actions ─────────────────────────────────────────── */
  .navbar-actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .desktop-socials {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .divider {
    display: block;
    width: 1px;
    height: 20px;
    background: var(--text);
    opacity: 0.12;
  }

  /* ── Hamburger ───────────────────────────────────────── */
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    border-radius: 9px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .hamburger:hover {
    background: color-mix(in srgb, var(--text) 6%, transparent);
    border-color: color-mix(in srgb, var(--text) 18%, transparent);
  }

  /* SVG line transitions */
  .h-top,
  .h-bot {
    transform-origin: center;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
  }

  .hamburger.is-active .h-top {
    transform: translateY(5px) rotate(45deg);
  }
  .hamburger.is-active .h-bot {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* ── Mobile overlay ──────────────────────────────────── */
  .mobile-overlay {
    display: none; /* JS reveals via class */
    position: fixed;
    inset: 0;
    z-index: 199;
    padding: 90px 2rem 2.5rem;
    flex-direction: column;
    justify-content: space-between;

    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);

    /* Entrance/exit */
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
    transition:
      opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-overlay.is-open {
    display: flex;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Watermark */
  .overlay-watermark {
    position: absolute;
    bottom: -0.5rem;
    right: 1.5rem;
    font-family: var(--font-main);
    font-size: clamp(5rem, 22vw, 9rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--text);
    opacity: 0.03;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  /* Mobile nav links — editorial style */
  .overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 7%, transparent);
    text-decoration: none;
    color: var(--text);
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.45s ease,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Stagger — each link gets a delay via nth-child */
  .mobile-overlay.is-open .mobile-link:nth-child(1) { transition-delay: 0.06s; opacity: 1; transform: translateY(0); }
  .mobile-overlay.is-open .mobile-link:nth-child(2) { transition-delay: 0.12s; opacity: 1; transform: translateY(0); }
  .mobile-overlay.is-open .mobile-link:nth-child(3) { transition-delay: 0.18s; opacity: 1; transform: translateY(0); }

  .ml-index {
    font-family: var(--font-code);
    font-size: 0.65rem;
    font-weight: 500;
    opacity: 0.25;
    letter-spacing: 0.04em;
    width: 22px;
    flex-shrink: 0;
  }

  .ml-label {
    flex: 1;
    font-size: clamp(1.9rem, 8vw, 2.8rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    transition: opacity 0.2s;
  }

  .mobile-link--active .ml-label {
    font-weight: 600;
    color: var(--brand);
  }

  .mobile-link--active .ml-index {
    color: var(--brand);
    opacity: 0.6;
  }

  .ml-arrow {
    opacity: 0;
    transform: translate(-6px, 6px);
    transition: opacity 0.2s, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    flex-shrink: 0;
    color: var(--brand);
  }

  .mobile-link:hover .ml-label { opacity: 0.6; }
  .mobile-link:hover .ml-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }
  .mobile-link--active .ml-arrow {
    opacity: 0.5;
    transform: translate(0, 0);
  }

  /* Overlay footer */
  .overlay-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--text) 7%, transparent);

    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease 0.28s, transform 0.4s ease 0.28s;
  }

  .mobile-overlay.is-open .overlay-footer {
    opacity: 1;
    transform: translateY(0);
  }

  .overlay-socials {
    display: flex;
    gap: 1.25rem;
  }

  .overlay-brand-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-family: var(--font-code);
    opacity: 0.25;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .hamburger        { display: flex; }
    .desktop-socials  { display: none; }
    .divider          { display: none; }
    .nav-links        { display: none; }

    .navbar-container {
      grid-template-columns: 1fr auto;
    }
  }

  @media (min-width: 769px) {
    .mobile-overlay { display: none !important; }
  }
</style>
