---
import Icon from "./Icon.astro";

interface Props {
  name: keyof typeof import("../utils/brands").BRANDS;
  href: string;
  label?: string;
}

const { name, href, label } = Astro.props as Props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label ?? name}
  class="social-link"
>
  <Icon name={name} />
</a>

<style>
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 0.25rem;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
    color: var(--text-color);
  }

  .social-link svg {
    width: var(--icon-size, 24px);
    height: var(--icon-size, 24px);
    fill: currentColor;
    stroke: currentColor;
    transition:
      transform 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .social-link:hover {
    /* color: var(--accent-color); */
    transform: scale(1.1);
    opacity: 0.7;
  }
</style>
