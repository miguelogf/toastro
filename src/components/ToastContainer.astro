---
import { ICONS } from "../utils/icons";
---

<div id="toast-container" class="toast-container"></div>

<script is:inline define:vars={{ ICONS }}>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("toast-container");
    if (!container) return;

    window.showToast = function ({
      message,
      type = "default",
      variant = "solid",
      icon = undefined, // Puede ser string (SVG), null o undefined
      color,
      gradientColors,
      duration = 4000,
    }) {
      const toast = document.createElement("div");

      // Mantenemos tus clases exactas
      toast.className = `toast type type--${type} variant--${variant}`;

      // Variables CSS dinámicas
      if (color) {
        toast.style.setProperty("--type-color", color);
      }

      if (gradientColors?.length) {
        toast.style.setProperty(
          "--toast-gradient",
          `linear-gradient(90deg, ${gradientColors.join(",")})`,
        );
      }

      // --- Lógica de Icono (Mejorada) ---
      let iconHTML = "";
      if (icon !== null) {
        // 1. Icono personalizado (string) | 2. Icono por type de la carpeta utils | 3. Default
        iconHTML =
          typeof icon === "string" ? icon : ICONS[type] || ICONS.default;
      }

      toast.innerHTML = `
        ${iconHTML ? `<div class="toast-icon">${iconHTML}</div>` : ""}
        <div class="toast-content">${message}</div>
      `;

      container.appendChild(toast);

      void toast.offsetWidth;
      toast.style.animation = "slide-in 0.3s forwards";

      setTimeout(() => {
        toast.style.animation = "slide-out 0.3s forwards";
        toast.addEventListener(
          "animationend",
          () => {
            toast.remove();
          },
          { once: true },
        );
      }, duration);
    };
  });
</script>

<style is:global>
  .toast-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    z-index: 9999;
    pointer-events: none;
  }

  .toast {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem; /* Ajustado para que se vea más pro */
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 500;
    width: fit-content;
    max-width: 350px;
    /* Sombra para dar profundidad (elevación) */
    box-shadow:
      0 4px 10px rgba(0, 0, 0, 0.08),
      0 10px 30px rgba(0, 0, 0, 0.12);
    opacity: 0;
    /* Eliminamos el text-align center para que con icono se vea ordenado */
  }

  .toast-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .toast-content {
    line-height: 1.4;
    text-align: left;
  }

  @keyframes slide-in {
    from {
      opacity: 0;
      transform: translateX(100%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slide-out {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(100%);
    }
  }

  /* @keyframes slide-in {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes slide-out {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(10px) scale(0.95);
    }
  } */

  @media (max-width: 640px) {
    .toast-container {
      right: 0;
      left: 0;
      bottom: 1.5rem;
      padding: 0 1rem; /* Espaciado lateral para que no toquen los bordes */
    }

    .toast {
      max-width: 280px; /* Aún más compacto en pantallas pequeñas */
      padding: 0.5rem 0.85rem;
      box-shadow: 0 4px 12px rgba(100, 100, 100, 0.2);
      font-size: 0.7rem;
    }

    .toast-icon {
      width: 16px;
      height: 16px;
    }
  }
</style>
