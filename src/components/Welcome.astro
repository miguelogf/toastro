---
import Badge from "../components/Badge.astro";
import ToastContainer from "../components/ToastContainer.astro";
import "../styles/global.css";
import logoLight from "../assets/logo-light.svg";
import logoDark from "../assets/logo-dark.svg";
import Button from "../components/Button.astro";
---

<div id="container">
  <main class="text-center">
    <section class="hero">
      <Badge
        label="Coming Soon"
        theme="gradient"
        color="var(--accent-toast)"
        gradientColors={["#f97316", "#e50a64"]}
      />
      <!-- <img src={logoLight} alt="Logo claro" class="block dark:hidden" />
        <img src={logoDark} alt="Logo oscuro" class="hidden dark:block" /> -->
      <div class="logo-container">
        <div class="logo-wrapper">
          <img src={logoDark.src} alt="Logo" class="logo-dark" />
          <img src={logoLight.src} alt="Logo" class="logo-light" />
        </div>
          
        <h1 class="logo-text">
          
          toas<span class="text-gradient-toastro">tro</span>
        </h1>
      </div>
      <h2 class="description">
        A beautiful and minimal<br />
        <span class="text-gradient-orange">toast</span> for
        <span class="text-gradient-pink">Astro.</span>
      </h2>
      <div class="buttons">
      <Button id="btn-toast" >Show toast</Button>
      <Button href="https://github.com/miguelogf/toastro/tree/main" variant="outline" newTab>Documentation</Button>
      </div>
      <script>
        document.addEventListener("DOMContentLoaded", () => {
          const btn = document.getElementById("btn-toast");
          if (btn) {
            btn.addEventListener("click", () => {
              window.showToast({ message: "Coming Soon!" });
            });
          }
        });
      </script>
    </section>
  </main>
</div>
<ToastContainer />
<div class="toast-test">
  Test
</div>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center; /* centra horizontalmente */
    justify-content: center; /* centra verticalmente (opcional) */
  }
  
  .logo-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: .5rem; /* espacio entre el logo y el texto */
    
    
  }
  /* 1. Lógica de visibilidad por defecto (Modo Claro) */
  .logo-dark {
    display: none !important;
  }
  .logo-light {
    display: block !important;
  }

  /* 2. Lógica para Modo Oscuro (Nativo del sistema) */
  html.dark  {
    .logo-light {
      display: none !important;
    }
    .logo-dark {
      display: block !important;
    }
  }
  .logo-text {
    display: inline-flex;
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -1px;
    margin: 1rem 0;
  }
  .logo-wrapper {
    width: 2rem; /* ajusta el tamaño del icono */
    height: auto;
  }
  .description {
    font-size: 3rem;
    font-weight: 200;
    margin: 0;
    text-align: center; /* centra el texto */
  }

  .text-gradient-toastro {
    background: linear-gradient(to right, #f97316, #ff000e, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .text-gradient-orange {
    background: linear-gradient(to right, #f97316, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }
  .text-gradient-pink {
    background: linear-gradient(to right, #ec4899, #bf0055);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
    /* Responsive - Tablet (768px y menores) */
  @media (max-width: 768px) {
    .hero {
      padding: 0 1.5rem;
      gap: 0.75rem;
    }

    .description {
      font-size: 2.5rem;
      padding: 0 0.75rem;
    }
  }

  /* Responsive - Móvil (480px y menores) */
  @media (max-width: 480px) {
    .hero {
      padding: 0 1rem;
      gap: 0.5rem;
    }

    .logo-text {
      font-size: 2.5rem;
    }

    .logo-text img {
      width: 2rem;
    }

    .description {
      font-size: 1.75rem;
      padding: 0 0.5rem;
    }
</style>
