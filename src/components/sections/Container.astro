---
// src/components/Section.astro
interface Props {
  class?: string;
  id?: string;
  label?: string;
  title?: string;
  subtitle?: string;
}

const { class: className, id, label, title, subtitle } = Astro.props;
---

<section id={id} class:list={["section", className]}>
  <div class="section-inner">
    {label && <div class="label-tag">{label}</div>}
    {title && <h2 class="section-title" set:html={title} />}
    {subtitle && <p class="section-sub">{subtitle}</p>}
    
    <slot />
  </div>
</section>

<style>
  .section {
    position: relative;
    padding: 6rem 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
  }

  .section-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .label-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-family: var(--font-code);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    opacity: 0.8;
    margin-bottom: 1rem;
  }
  .section-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .section-sub {
    font-size: 1rem;
    opacity: 0.5;
    margin: 0 0 3rem;
  }
</style>