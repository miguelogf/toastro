---
import Section from "@sections/Container.astro";
import Card from "@ui/Card.astro";
import Icon from "@ui/Icon.astro";
---

<Section
  label="Why toastro"
  title="Everything you need.<br/><em>Nothing you don't.</em>"
  subtitle="Built for Astro from the ground up — minimal by design, flexible by nature."
  class="bento-section"
>
  <div class="bento-grid">
    <!-- ① Zero deps — tall left, spans 2 rows -->
    <div class="bento-cell cell-zero">
      <Card interactive={true} reveal={true}>
        <div class="inner">
          <span class="blabel">Zero dependencies</span>
          <div class="zero-hero">
            <span class="zero-num">0</span>
            <span class="zero-unit">deps</span>
          </div>
          <p>Pure web platform APIs. No install bloat, no supply-chain risk.</p>
          <div class="zero-rings" aria-hidden="true">
            <div class="ring r1"></div>
            <div class="ring r2"></div>
            <div class="ring r3"></div>
          </div>
          <span class="size-pill">~2 kb gzipped</span>
        </div>
      </Card>
    </div>

    <!-- ② Variants — wide, 8 variants in 2-col grid -->
    <div class="bento-cell cell-variants">
      <Card interactive={true} reveal={true}>
        <div class="inner">
          <span class="blabel">8 variants</span>
          <strong>Every visual style, covered</strong>
          <div class="variants-grid">
            <div class="vitem">
              <div class="tmock tmock-solid">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">solid</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-soft">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">soft</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-subtle">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">subtle</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-outline">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">outline</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-ghost">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">ghost</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-surface">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">surface</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-glass">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">glass</span>
            </div>
            <div class="vitem">
              <div class="tmock tmock-gradient">
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                > Saved!
              </div>
              <span class="vtag">gradient</span>
            </div>
          </div>
        </div>
      </Card>
    </div>

    <!-- ③ Global API — code block -->
    <div class="bento-cell cell-api">
      <Card interactive={true} reveal={true}>
        <div class="inner inner-api">
          <span class="blabel">Global API</span>
          <strong>Call from anywhere</strong>
          <div class="codeblock">
            <div class="cl">
              <span class="c-obj">window</span><span class="c-p">.</span><span
                class="c-fn">showToast</span
              ><span class="c-p">(&#123;</span>
            </div>
            <div class="cl ci">
              <span class="c-key">message</span><span class="c-p">:</span>
              <span class="c-str">"Saved! 🍞"</span><span class="c-p">,</span>
            </div>
            <div class="cl ci">
              <span class="c-key">type</span><span class="c-p">:</span>
              <span class="c-str">"success"</span><span class="c-p">,</span>
            </div>
            <div class="cl ci">
              <span class="c-key">variant</span><span class="c-p">:</span>
              <span class="c-str">"glass"</span><span class="c-p">,</span>
            </div>
            <div class="cl"><span class="c-p">&#125;);</span></div>
          </div>
          <p class="api-sub">
            No imports needed — available globally once <code
              >&lt;ToastContainer /&gt;</code
            > is mounted.
          </p>
        </div>
      </Card>
    </div>

    <!-- ④ Positions -->
    <div class="bento-cell cell-pos">
      <Card interactive={true} reveal={true}>
        <div class="inner inner-pos">
          <span class="blabel">7 positions</span>
          <strong>Place it anywhere</strong>
          <div class="pos-wrap">
            <div class="pos-screen">
              <div class="pd tl"></div>
              <div class="pd tc"></div>
              <div class="pd tr"></div>
              <div class="pd mc"></div>
              <div class="pd bl"></div>
              <div class="pd bc"></div>
              <div class="pd br pd-active">🍞</div>
            </div>
          </div>
          <p>Animation adapts to each corner automatically.</p>
        </div>
      </Card>
    </div>

    <!-- ⑤ Bundle size — brand accent card -->
    <div class="bento-cell cell-bundle">
      <Card interactive={true} reveal={true}>
        <div class="inner inner-bundle">
          <span class="blabel">Bundle size</span>
          <strong>Lighter than the competition</strong>
          <div class="bars">
            <div class="bar-row">
              <span class="bar-name bar-name--brand">toastro</span>
              <div class="bar-track">
                <div class="bar-fill bar-fill--brand" style="width: 13%">
                  <span class="bar-val">2kb</span>
                </div>
              </div>
            </div>
            <div class="bar-row">
              <span class="bar-name">sonner</span>
              <div class="bar-track">
                <div class="bar-fill bar-fill--mid" style="width: 55%">
                  <span class="bar-val">8kb</span>
                </div>
              </div>
            </div>
            <div class="bar-row">
              <span class="bar-name">react-hot-toast</span>
              <div class="bar-track">
                <div class="bar-fill bar-fill--dim" style="width: 100%">
                  <span class="bar-val">15kb</span>
                </div>
              </div>
            </div>
          </div>
          <p class="bundle-note">gzipped · no framework overhead</p>
        </div>
      </Card>
    </div>

    <!-- ⑥ Types — 5 cards -->
    <div class="bento-cell cell-types">
      <Card interactive={true} reveal={true}>
        <div class="inner inner-types">
          <div class="types-head">
            <span class="blabel">5 types</span>
            <strong>Built-in semantic intent</strong>
          </div>
          <div class="types-grid">
            <div class="tcard tc-success"><Icon name="success" />success</div>
            <div class="tcard tc-error"><Icon name="error" /></div>error
          </div>
          <div class="tcard tc-warning"><Icon name="warning" /></div>warning
        </div>
        <div class="tcard tc-info"><Icon name="info" /></div>info</Card
      >
      <div class="tcard tc-default"><Icon name="neutral" /></div>default
    </div>
  </div>
</Section>

<!-- ⑦ CSS Theming — 2 cols -->
<div class="bento-cell cell-theme">
  <Card interactive={true} reveal={true}>
    <div class="inner inner-theme">
      <div class="theme-left">
        <span class="blabel">CSS Variables</span>
        <strong>Inherits your design system</strong>
        <p>
          Toastro reads your existing CSS variables automatically. Drop it in
          and it already looks right — no extra config needed.
        </p>
        <div class="theme-swatches">
          <span class="sw sw-bg"></span>
          <span class="sw sw-brand"></span>
          <span class="sw sw-text"></span>
          <span class="sw-label">your tokens →</span>
        </div>
      </div>
      <div class="theme-code">
        <div class="tc-filename">global.css</div>
        <div class="cl">
          <span class="tc-sel">:root</span>
          <span class="c-p">&#123;</span>
        </div>
        <div class="cl ci">
          <span class="tc-var">--toastro-bg</span><span class="c-p">:</span>
          <span class="tc-val">var(--bg-color)</span><span class="c-p">;</span>
          <span class="tc-cmt">/* background */</span>
        </div>
        <div class="cl ci">
          <span class="tc-var">--toastro-text</span><span class="c-p">:</span>
          <span class="tc-val">var(--text-color)</span><span class="c-p">;</span
          >
          <span class="tc-cmt">/* text */</span>
        </div>
        <div class="cl ci">
          <span class="tc-var">--toastro-radius</span><span class="c-p">:</span>
          <span class="tc-val">12px</span><span class="c-p">;</span>
          <span class="tc-cmt">/* corners */</span>
        </div>
        <div class="cl"><span class="c-p">&#125;</span></div>
      </div>
    </div>
  </Card>
</div>

<!-- ⑧ MIT License — compact -->
<div class="bento-cell cell-mit">
  <Card interactive={true} reveal={true}>
    <div class="inner inner-mit">
      <div class="mit-free">
        <Icon name="dollar" />
      </div>
      <span class="blabel">MIT License</span>
      <strong>Free forever</strong>
      <p>
        Use, modify, and distribute — personal or commercial projects. No
        strings attached.
      </p>
      <div class="mit-badge">Open Source</div>
    </div>
  </Card>
</div>

<style>
  /* ─────────────────────────────────────────
     GRID — cells are regular block grid items
     Card inside is told to fill 100% height
  ───────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1.35fr 0.9fr;
    grid-template-rows: auto auto auto auto;
    gap: 0.85rem;
  }

  /* Cells are plain grid items */
  .bento-cell {
    display: block;
    min-width: 0;
  }

  /* Stretch Card to fill the cell */
  .bento-cell > :global(.card-base) {
    height: 100%;
    box-sizing: border-box;
  }

  /* Grid positions */
  .cell-zero {
    grid-column: 1;
    grid-row: 1 / 3;
  }
  .cell-variants {
    grid-column: 2 / 4;
    grid-row: 1;
  }
  .cell-api {
    grid-column: 2;
    grid-row: 2;
  }
  .cell-pos {
    grid-column: 3;
    grid-row: 2;
  }
  .cell-bundle {
    grid-column: 1;
    grid-row: 3;
  }
  .cell-types {
    grid-column: 2 / 4;
    grid-row: 3;
  }
  .cell-theme {
    grid-column: 1 / 3;
    grid-row: 4;
  }
  .cell-mit {
    grid-column: 3;
    grid-row: 4;
  }

  /* ─────────────────────────────────────────
     SHARED INNER
  ───────────────────────────────────────── */
  .inner {
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    box-sizing: border-box;
  }

  .inner strong {
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.3;
  }

  .inner p {
    font-size: 0.76rem;
    opacity: 0.42;
    line-height: 1.65;
    margin: 0;
  }

  .blabel {
    font-size: 0.6rem;
    font-family: var(--font-code);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    opacity: 0.75;
  }

  /* ─────────────────────────────────────────
     ① ZERO DEPS
  ───────────────────────────────────────── */
  .cell-zero > :global(.card-base) {
    background: color-mix(in srgb, var(--brand) 4%, transparent) !important;
    border-color: color-mix(in srgb, var(--brand) 15%, transparent) !important;
    overflow: hidden;
  }

  .cell-zero .inner {
    position: relative;
    justify-content: flex-start;
    min-height: 300px;
    gap: 0.5rem;
  }

  .zero-hero {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    margin-top: 0.25rem;
    line-height: 1;
  }

  .zero-num {
    font-size: clamp(5.5rem, 9vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    color: var(--brand);
    line-height: 0.88;
    position: relative;
    z-index: 1;
  }

  .zero-unit {
    font-size: 1.5rem;
    font-weight: 700;
    opacity: 0.25;
    letter-spacing: -0.02em;
    align-self: flex-end;
    margin-bottom: 0.4rem;
  }

  .cell-zero .inner > p {
    position: relative;
    z-index: 1;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    max-width: 200px;
  }

  /* Decorative rings */
  .zero-rings {
    position: absolute;
    bottom: -80px;
    right: -80px;
    pointer-events: none;
    z-index: 0;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--brand) 12%, transparent);
    transform: translate(-50%, -50%);
    top: 0;
    left: 0;
  }
  .r1 {
    width: 150px;
    height: 150px;
  }
  .r2 {
    width: 240px;
    height: 240px;
    border-color: color-mix(in srgb, var(--brand) 7%, transparent);
  }
  .r3 {
    width: 330px;
    height: 330px;
    border-color: color-mix(in srgb, var(--brand) 3%, transparent);
  }

  .size-pill {
    display: inline-flex;
    align-self: flex-start;
    font-size: 0.63rem;
    font-family: var(--font-code);
    padding: 0.28rem 0.65rem;
    border-radius: 99px;
    background: color-mix(in srgb, var(--brand) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand) 25%, transparent);
    color: var(--brand);
    letter-spacing: 0.04em;
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  /* ─────────────────────────────────────────
     ② VARIANTS — 2-column grid of 8
  ───────────────────────────────────────── */
  .variants-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.45rem;
    margin-top: 0.2rem;
  }

  .vitem {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tmock {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    padding: 0.38rem 0.75rem;
    border-radius: 7px;
    font-weight: 500;
    width: 100%;
    box-sizing: border-box;
  }

  .vtag {
    font-family: var(--font-code);
    font-size: 0.58rem;
    opacity: 0.3;
    letter-spacing: 0.05em;
    padding-left: 0.1rem;
  }

  /* All 8 variants matching actual CSS */
  .tmock-solid {
    background: #34d399;
    color: #fff;
    border: 1px solid #34d399;
  }
  .tmock-soft {
    background: color-mix(in srgb, #34d399 15%, transparent);
    color: #34d399;
    border: 1px solid transparent;
  }
  .tmock-subtle {
    background: color-mix(in srgb, #34d399 6%, transparent);
    color: #34d399;
    border: 1px solid color-mix(in srgb, #34d399 20%, transparent);
  }
  .tmock-outline {
    background: transparent;
    color: #34d399;
    border: 1px solid #34d399;
  }
  .tmock-ghost {
    background: transparent;
    color: #34d399;
    border: 1px solid transparent;
  }
  .tmock-surface {
    border: 1px solid color-mix(in srgb, var(--text) 15%, transparent);
    color: #34d399;
    background: color-mix(in srgb, var(--text) 5%, transparent);
  }
  .tmock-glass {
    background: color-mix(in srgb, var(--text) 6%, transparent);
    color: var(--text);
    border: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
    backdrop-filter: blur(12px) saturate(180%);
  }
  .tmock-gradient {
    border: 1px solid transparent;
    color: #f97316;
    background:
      linear-gradient(
          color-mix(in srgb, var(--text) 5%, transparent),
          color-mix(in srgb, var(--text) 5%, transparent)
        )
        padding-box,
      linear-gradient(90deg, #f97316, #f31b75) border-box;
    background-origin: border-box;
    background-clip: padding-box, border-box;
  }

  /* ─────────────────────────────────────────
     ③ GLOBAL API
  ───────────────────────────────────────── */
  .inner-api {
    justify-content: space-between;
  }

  .codeblock {
    font-family: var(--font-code);
    font-size: 0.72rem;
    line-height: 1.9;
    padding: 0.85rem 1rem;
    background: color-mix(in srgb, var(--text) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
    border-radius: 8px;
    flex: 1;
  }

  .cl {
    display: block;
    white-space: nowrap;
  }
  .ci {
    padding-left: 1.1em;
  }

  .c-obj {
    opacity: 0.45;
  }
  .c-p {
    opacity: 0.28;
  }
  .c-fn {
    color: #82aaff;
  }
  .c-key {
    color: #89ddff;
  }
  .c-str {
    color: #c3e88d;
  }

  .api-sub {
    font-size: 0.72rem !important;
    opacity: 0.38 !important;
    margin-top: 0 !important;
  }

  .api-sub code {
    font-family: var(--font-code);
    font-size: 0.85em;
    background: color-mix(in srgb, var(--text) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    padding: 0.05em 0.35em;
    border-radius: 3px;
  }

  /* ─────────────────────────────────────────
     ④ POSITIONS
  ───────────────────────────────────────── */
  .inner-pos {
    align-items: flex-start;
    justify-content: space-between;
  }

  .pos-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 0.5rem 0;
    width: 100%;
  }

  .pos-screen {
    position: relative;
    width: 112px;
    height: 80px;
    border: 1.5px solid color-mix(in srgb, var(--text) 14%, transparent);
    border-radius: 7px;
    background: color-mix(in srgb, var(--text) 2%, transparent);
  }

  .pd {
    position: absolute;
    width: 24px;
    height: 13px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--text) 9%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 13%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 7px;
  }

  .tl {
    top: 5px;
    left: 5px;
  }
  .tc {
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
  }
  .tr {
    top: 5px;
    right: 5px;
  }
  .mc {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .bl {
    bottom: 5px;
    left: 5px;
  }
  .bc {
    bottom: 5px;
    left: 50%;
    transform: translateX(-50%);
  }
  .br {
    bottom: 5px;
    right: 5px;
  }

  .pd-active {
    background: color-mix(in srgb, var(--brand) 22%, transparent) !important;
    border-color: color-mix(in srgb, var(--brand) 45%, transparent) !important;
    color: var(--brand);
    width: 30px;
    height: 17px;
    box-shadow: 0 0 10px color-mix(in srgb, var(--brand) 20%, transparent);
  }

  /* ─────────────────────────────────────────
     ⑤ BUNDLE SIZE — brand accent
  ───────────────────────────────────────── */
  .inner-bundle {
    justify-content: space-between;
    gap: 0.9rem;
  }

  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
    justify-content: center;
  }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .bar-name {
    font-size: 0.65rem;
    font-family: var(--font-code);
    opacity: 0.4;
    flex: 0 0 94px;
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-name--brand {
    color: var(--brand);
    opacity: 0.9;
    font-weight: 600;
  }

  .bar-track {
    flex: 1;
    height: 22px;
    background: color-mix(in srgb, var(--text) 5%, transparent);
    border-radius: 5px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.45rem;
    min-width: 32px;
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bar-fill--brand {
    background: var(--brand);
  }

  .bar-fill--mid {
    background: color-mix(in srgb, var(--text) 22%, transparent);
  }

  .bar-fill--dim {
    background: color-mix(in srgb, var(--text) 14%, transparent);
  }

  .bar-val {
    font-family: var(--font-code);
    font-size: 0.6rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--bg) 90%, transparent);
    opacity: 1;
  }

  .bar-fill--brand .bar-val {
    color: #fff;
  }
  .bar-fill--mid .bar-val,
  .bar-fill--dim .bar-val {
    color: var(--text);
    opacity: 0.5;
  }

  .bundle-note {
    font-size: 0.65rem !important;
    opacity: 0.3 !important;
