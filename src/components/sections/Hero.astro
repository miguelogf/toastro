---
import Badge from "@ui/Badge.astro";
import Button from "@ui/Button.astro";
import Icon from "@ui/Icon.astro";
---

<section class="hero">
  <div class="hero-content">
    <Badge variant="subtle" class="badge-hero" animate="fade">
      <span class="badge-dot"></span>Open Source · MIT Licensed</Badge
    >
    <h1 class="hero-title">
      <span class="title-line">the toast lib</span>
      <span class="title-line accent">Astro deserved.</span>
    </h1>
    <p class="hero-sub">
      Beautiful, zero-dependency toast notifications for Astro.<br />
      No framework. No noise. Just bread. 🍞
    </p>
    <div class="buttons">
      <Button href="/docs" id="btn-toast" fullWidth
        >Get Started<Icon name="arrowUpRight" /></Button
      >
      <Button href="#builder" variant="outline" fullWidth>
        Try it now<Icon name="zap" />
      </Button>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <Icon name="arrow" />
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 80px); /* calc(100vh - 80px); */
    display: grid;
    place-items: center;
    position: relative;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
  }

  :global(.badge-hero) {
    margin-bottom: 2rem;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-success);
    animation: pulse 2s ease infinite;
  }

  .hero-title {
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0 0 1.5rem;
  }

  .title-line {
    display: block;
    animation: fadeUp 0.6s ease both;
  }

  .title-line:first-child {
    animation-delay: 0.1s;
    opacity: 0.55;
  }
  .title-line:last-child {
    animation-delay: 0.2s;
  }

  .title-line.accent {
    color: var(--brand);
    opacity: 1;
  }

  .hero-sub {
    font-size: 1.1rem;
    opacity: 0.55;
    line-height: 1.7;
    margin: 0 0 2.5rem;
    text-wrap: balance;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.4s ease both;
  }

  #btn-toast {
    gap: 0.25rem;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    translate: -50% 0;
    z-index: 1;
    opacity: 0.3;
    animation: float 3s ease-in-out infinite;
  }

  @media (max-width: 640px) {
    .logo-wrapper {
      width: 2rem;
    }

    .logo-text {
      font-size: 2.5rem;
    }

    .hero-title {
      text-wrap: balance;
      max-width: 20ch;
    }

    .buttons {
      flex-direction: column;
      width: 90%;
      margin: 2rem auto 4rem auto;
    }
  }
</style>
