---
import "@fontsource-variable/montserrat";
import "@fontsource/fira-code";

import "../styles/global.css";
import "../styles/theme.css";

import NavBar from "../components/NavBar.astro";
import ParticlesBackground from "../components/ParticlesBackground.astro";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <!-- Base -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>toastro — Minimal toast for Astro</title>
    <meta
      name="description"
      content="Minimal, agnostic and elegant toast component for Astro."
    />
    <meta name="author" content="mogf.dev" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href="https://toastro.vercel.app" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="toastro — Minimal toast for Astro" />
    <meta
      property="og:description"
      content="Minimal, agnostic and elegant toast component for Astro."
    />
    <meta property="og:url" content="https://toastro.vercel.app" />
    <meta
      property="og:image"
      content="https://toastro.vercel.app/og-image.png"
    />
    <meta property="og:site_name" content="toastro" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="toastro — Minimal toast for Astro" />
    <meta
      name="twitter:description"
      content="Minimal, agnostic and elegant toast component for Astro."
    />
    <meta
      name="twitter:image"
      content="https://toastro.vercel.app/og-image.png"
    />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <ParticlesBackground />
    <NavBar />
    <main style="position:relative; z-index:1;">
      <slot />
    </main>
  </body>
</html>
