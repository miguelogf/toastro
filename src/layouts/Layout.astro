---
import "../styles/global.css";
import "@fontsource-variable/montserrat";
import "@fontsource/fira-code";
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Este script evita el "flash" blanco al cargar
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      })();

      document.documentElement.setAttribute("data-theme", theme);
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>toastro - Minimal toast for Astro</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Usamos is:global para que afecte a toda la web */
  :root {
    /* Valores por defecto (Light Mode) */
    --bg-color: #ededed;
    --text-color: #060606;
    --accent-toast: #f97316;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      /* Valores para Dark Mode */
      --bg-color: #000000;
      --text-color: #ededed;
    }
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background-color: var(--bg-color);
    color: var(--text-color);
    transition: background-color 1s ease; /* Transición suave */
    font-family: "Montserrat Variable", sans-serif;

    display: flex;
    justify-content: center;
    align-items: center;
  }
  .blur-gradient {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(
      circle,
      rgba(255, 100, 0, 0.15) 0%,
      rgba(0, 0, 0, 0) 70%
    );
    filter: blur(50px);
    z-index: -1;
  }
</style>
