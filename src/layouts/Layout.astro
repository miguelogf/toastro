---
import "../styles/global.css";
import "@fontsource-variable/montserrat";
import "@fontsource/fira-code";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Base -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>toastro — Minimal toast for Astro</title>
    <meta
      name="description"
      content="Minimal, agnostic and elegant toast component for Astro."
    />
    <meta name="author" content="mogf.dev" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href="https://toastro.vercel.app" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="toastro — Minimal toast for Astro" />
    <meta
      property="og:description"
      content="Minimal, agnostic and elegant toast component for Astro."
    />
    <meta property="og:url" content="https://toastro.vercel.app" />
    <meta
      property="og:image"
      content="https://toastro.vercel.app/og-image.png"
    />
    <meta property="og:site_name" content="toastro" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="toastro — Minimal toast for Astro" />
    <meta
      name="twitter:description"
      content="Minimal, agnostic and elegant toast component for Astro."
    />
    <meta
      name="twitter:image"
      content="https://toastro.vercel.app/og-image.png"
    />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Theme init (evita flicker) -->
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return "dark";
      })();

      document.documentElement.classList.toggle("dark", theme !== "light");
      localStorage.setItem("theme", theme);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Usamos is:global para que afecte a toda la web */
  :root {
    /* Valores por defecto (Light Mode) */
    --bg-color: #ededed;
    --text-color: #1d1d1d;
    --accent-toast: #f97316;
  }

  html.dark {
    /* Valores para Dark Mode */
    --bg-color: #000000;
    --text-color: #ededed;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background-color: var(--bg-color);
    color: var(--text-color);
    transition: bg-color 1s ease; /* Transición suave */
    font-family: "Montserrat Variable", sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
