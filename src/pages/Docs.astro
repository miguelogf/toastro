---
// src/pages/docs.astro  (or src/components/Docs.astro)
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import Icon from "../components/Icon.astro";
---

<Layout title="Docs — toastro">
  <div class="docs-page">
    <!-- Sidebar -->
    <aside class="sidebar">
      <nav class="sidebar-nav">
        <span class="sidebar-label">Getting Started</span>
        <a href="#installation" class="sidebar-link">Installation</a>
        <a href="#setup" class="sidebar-link">Setup</a>
        <a href="#usage" class="sidebar-link">Usage</a>

        <span class="sidebar-label">Customization</span>
        <a href="#types" class="sidebar-link">Types</a>
        <a href="#variants" class="sidebar-link">Variants</a>
        <a href="#positions" class="sidebar-link">Positions</a>
        <a href="#icons" class="sidebar-link">Custom Icons</a>
        <a href="#colors" class="sidebar-link">Custom Colors</a>
        <a href="#duration" class="sidebar-link">Duration</a>
        <a href="#theming" class="sidebar-link">CSS Theming</a>

        <span class="sidebar-label">Reference</span>
        <a href="#api" class="sidebar-link">API Reference</a>
      </nav>
    </aside>

    <!-- Content -->
    <main class="docs-content">
      <!-- Header -->
      <div class="docs-header">
        <Badge
          label="Documentation"
          variant="outline"
          color="var(--text-color)"
          styleOverride="opacity: 0.4; text-transform: uppercase; letter-spacing: 0.07em; margin: 0 0 1rem 0;"
        />
        <h1>Getting Started</h1>
        <p class="docs-intro">
          A beautiful and minimal toast notification library for Astro. Install
          once, use everywhere — no framework overhead, no opinions.
        </p>
      </div>

      <!-- Installation -->
      <section id="installation" class="doc-section">
        <h2><span class="section-icon">📦</span> Installation</h2>
        <p>Install toastro using your preferred package manager:</p>

        <div class="code-tabs">
          <div class="code-tab-bar">
            <button class="tab-btn active" data-tab="npm"
              ><Icon name="npm" />npm</button
            >
            <button class="tab-btn" data-tab="bun"
              ><Icon name="bun" />bun</button
            >
            <button class="tab-btn" data-tab="pnpm"
              ><Icon name="pnpm" />pnpm</button
            >
            <button class="tab-btn" data-tab="yarn"
              ><Icon name="yarn" />yarn</button
            >
          </div>
          <div class="code-block" data-tab-content="npm">
            <button class="copy-btn" aria-label="Copy">
              <Icon name="copy" />
            </button>
            <pre><code><span class="token-comment"># install the package</span>
<span class="token-cmd">npm</span> install toastro</code></pre>
          </div>
          <div class="code-block hidden" data-tab-content="bun">
            <button class="copy-btn" aria-label="Copy">
              <Icon name="copy" />
            </button>
            <pre><code><span class="token-comment"># install the package</span>
<span class="token-cmd">bun</span> add toastro</code></pre>
          </div>
          <div class="code-block hidden" data-tab-content="pnpm">
            <button class="copy-btn" aria-label="Copy">
              <Icon name="copy" />
            </button>
            <pre><code><span class="token-comment"># install the package</span>
<span class="token-cmd">pnpm</span> add toastro</code></pre>
          </div>
          <div class="code-block hidden" data-tab-content="yarn">
            <button class="copy-btn" aria-label="Copy">
              <Icon name="copy" />
            </button>
            <pre><code><span class="token-comment"># install the package</span>
<span class="token-cmd">yarn</span> add toastro</code></pre>
          </div>
        </div>
      </section>

      <!-- Setup -->
      <section id="setup" class="doc-section">
        <h2><span class="section-icon">🛠️</span> Setup</h2>
        <p>
          Add <code>&lt;ToastContainer /&gt;</code> once in your main layout. It manages
          the notification queue and all animations automatically.
        </p>

        <div class="code-block">
          <div class="code-filename">src/layouts/Layout.astro</div>
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>---
import &lbrace; ToastContainer &rbrace; from 'toastro';
---

&lt;html lang="en"&gt;
  &lt;body&gt;
    &lt;slot /&gt;
    &lt;ToastContainer /&gt;
  &lt;/body&gt;
&lt;/html&gt;</code></pre>
        </div>

        <div class="callout callout-info">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="12" cy="12" r="10"></circle><line
              x1="12"
              y1="8"
              x2="12"
              y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
            ></line></svg
          >
          <span
            ><code>&lt;ToastContainer /&gt;</code> defaults to <code
              >position="bottom-right"</code
            >. See <a href="#positions">Positions</a> for all options.</span
          >
        </div>
      </section>

      <!-- Usage -->
      <section id="usage" class="doc-section">
        <h2><span class="section-icon">⚡</span> Usage</h2>
        <p>
          Call <code>window.showToast()</code> from any client script. No imports
          needed — it's globally available once <code
            >&lt;ToastContainer /&gt;</code
          > is mounted.
        </p>

        <div class="code-block">
          <div class="code-filename">src/pages/index.astro</div>
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>&lt;button id="btn"&gt;Show toast&lt;/button&gt;

&lt;script&gt;
  document.getElementById("btn").addEventListener("click", () =&gt; &lbrace;
    window.showToast(&lbrace;
      message: "Hello from toastro 🍞",
      type:    "success",
      variant: "glass",
    &rbrace;);
  &rbrace;);
&lt;/script&gt;</code></pre>
        </div>
      </section>

      <!-- Types -->
      <section id="types" class="doc-section">
        <h2><span class="section-icon">🏷️</span> Types</h2>
        <p>
          Use <code>type</code> to convey intent. Each type ships with a built-in
          icon.
        </p>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>window.showToast(&lbrace; message: "Saved!",            type: "success" &rbrace;);
window.showToast(&lbrace; message: "Something failed",  type: "error"   &rbrace;);
window.showToast(&lbrace; message: "Watch out",         type: "warning" &rbrace;);
window.showToast(&lbrace; message: "Just so you know",  type: "info"    &rbrace;);
window.showToast(&lbrace; message: "Plain message",     type: "default" &rbrace;);</code></pre>
        </div>

        <table class="docs-table">
          <thead><tr><th>Type</th><th>Icon</th><th>Use case</th></tr></thead>
          <tbody>
            <tr
              ><td><code>default</code></td><td>—</td><td>Neutral messages</td
              ></tr
            >
            <tr
              ><td><code>success</code></td><td>✓</td><td>Completed actions</td
              ></tr
            >
            <tr
              ><td><code>error</code></td><td>✕</td><td
                >Failures, validation errors</td
              ></tr
            >
            <tr
              ><td><code>warning</code></td><td>⚠</td><td
                >Non-critical alerts</td
              ></tr
            >
            <tr
              ><td><code>info</code></td><td>ℹ</td><td
                >Informational messages</td
              ></tr
            >
          </tbody>
        </table>
      </section>

      <!-- Variants -->
      <section id="variants" class="doc-section">
        <h2><span class="section-icon">🎨</span> Variants</h2>
        <p>Control the visual style of each toast with <code>variant</code>.</p>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>window.showToast(&lbrace; message: "Solid",   type: "success", variant: "solid"   &rbrace;);
window.showToast(&lbrace; message: "Soft",    type: "success", variant: "soft"    &rbrace;);
window.showToast(&lbrace; message: "Outline", type: "success", variant: "outline" &rbrace;);
window.showToast(&lbrace; message: "Glass",   type: "success", variant: "glass"   &rbrace;);</code></pre>
        </div>

        <table class="docs-table">
          <thead><tr><th>Variant</th><th>Description</th></tr></thead>
          <tbody>
            <tr>
              <td><code>solid</code></td>
              <td>
                Filled background, high contrast
                <Badge
                  label="default"
                  variant="soft"
                  type="default"
                  styleOverride="margin-left: 0.25rem;"
                />
              </td>
            </tr>
            <tr><td><code>soft</code></td><td>Subtle tint, low contrast</td></tr
            >
            <tr
              ><td><code>outline</code></td><td
                >Transparent background with colored border</td
              ></tr
            >
            <tr
              ><td><code>glass</code></td><td
                >Frosted glass effect with backdrop blur</td
              ></tr
            >
          </tbody>
        </table>
      </section>

      <!-- Positions -->
      <section id="positions" class="doc-section">
        <h2><span class="section-icon">📐</span> Positions</h2>
        <p>
          Pass <code>position</code> to <code>&lt;ToastContainer /&gt;</code> to control
          where toasts appear.
        </p>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>&lt;ToastContainer position="bottom-right"  /&gt;  &lt;!-- default --&gt;
&lt;ToastContainer position="bottom-left"   /&gt;
&lt;ToastContainer position="bottom-center" /&gt;
&lt;ToastContainer position="top-right"     /&gt;
&lt;ToastContainer position="top-left"      /&gt;
&lt;ToastContainer position="top-center"    /&gt;
&lt;ToastContainer position="center"        /&gt;</code></pre>
        </div>

        <div class="position-diagram">
          <div class="pos-dot top-left">top-left</div>
          <div class="pos-dot top-center">top-center</div>
          <div class="pos-dot top-right">top-right</div>
          <div class="pos-dot center">center</div>
          <div class="pos-dot bottom-left">bottom-left</div>
          <div class="pos-dot bottom-center">bottom-center</div>
          <div class="pos-dot bottom-right active">bottom-right</div>
        </div>

        <div class="callout callout-tip">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
            ></polygon></svg
          >
          <span
            >The slide-in animation adapts automatically: left positions slide
            from the left, right from the right, center positions from below.</span
          >
        </div>
      </section>

      <!-- Custom Icons -->
      <section id="icons" class="doc-section">
        <h2><span class="section-icon">✳️</span> Custom Icons</h2>
        <p>
          Pass a raw SVG string to override the default icon, or <code
            >null</code
          > to hide it entirely.
        </p>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>// Custom SVG icon
window.showToast(&lbrace;
  message: "Deployed to production",
  icon: `&lt;svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"&gt;
  &lt;path d="M12 19V5M5 12l7-7 7 7"/&gt;
&lt;/svg&gt;`,
&rbrace;);

// No icon
window.showToast(&lbrace;
  message: "Clean, iconless toast",
  icon: null,
&rbrace;);</code></pre>
        </div>
      </section>

      <!-- Custom Colors -->
      <section id="colors" class="doc-section">
        <h2><span class="section-icon">🌈</span> Custom Colors</h2>

        <h3>Solid color</h3>
        <p>
          Use <code>color</code> to set a custom accent that drives the icon, border,
          and highlights.
        </p>
        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>window.showToast(&lbrace;
  message: "Custom brand color",
  color:   "#6366f1",
&rbrace;);</code></pre>
        </div>

        <h3>Gradient</h3>
        <p>
          Pass an array of colors to <code>gradientColors</code> for a horizontal
          gradient background.
        </p>
        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>window.showToast(&lbrace;
  message:        "Gradient toast 🌈",
  gradientColors: ["#f97316", "#ec4899", "#8b5cf6"],
&rbrace;);</code></pre>
        </div>
      </section>

      <!-- Duration -->
      <section id="duration" class="doc-section">
        <h2><span class="section-icon">⏱️</span> Duration</h2>
        <p>
          Control how long (in ms) the toast stays visible. Defaults to <code
            >4000</code
          >.
        </p>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>window.showToast(&lbrace; message: "Quick!",   duration: 1500 &rbrace;);
window.showToast(&lbrace; message: "Lingers…", duration: 8000 &rbrace;);</code></pre>
        </div>
      </section>

      <!-- CSS Theming -->
      <section id="theming" class="doc-section">
        <h2><span class="section-icon">🎨</span> CSS Theming</h2>
        <p>
          Toastro uses CSS variables so it inherits your site's design system
          automatically. Override any of these in your global styles:
        </p>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>:root &lbrace;
  --toastro-bg:     var(--bg-color);    /* toast background */
  --toastro-text:   var(--text-color);  /* text color       */
  --toastro-radius: 12px;              /* border radius    */
&rbrace;</code></pre>
        </div>
      </section>

      <!-- API Reference -->
      <section id="api" class="doc-section">
        <h2><span class="section-icon">⚙️</span> API Reference</h2>

        <h3><code>&lt;ToastContainer /&gt;</code> props</h3>
        <table class="docs-table">
          <thead
            ><tr
              ><th>Prop</th><th>Type</th><th>Default</th><th>Description</th
              ></tr
            ></thead
          >
          <tbody>
            <tr>
              <td><code>position</code></td>
              <td><code>Position</code></td>
              <td><code>"bottom-right"</code></td>
              <td>Where toasts appear on screen</td>
            </tr>
          </tbody>
        </table>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>type Position =
  | "top-left"      | "top-center"    | "top-right"
  | "bottom-left"   | "bottom-center" | "bottom-right"
  | "center";</code></pre>
        </div>

        <h3><code>showToast(options)</code></h3>
        <table class="docs-table">
          <thead
            ><tr
              ><th>Option</th><th>Type</th><th>Default</th><th>Description</th
              ></tr
            ></thead
          >
          <tbody>
            <tr
              ><td><code>message</code></td><td><code>string</code></td><td
                ><span class="required">required</span></td
              ><td>The text content of the toast</td></tr
            >
            <tr
              ><td><code>type</code></td><td><code>ToastType</code></td><td
                ><code>"default"</code></td
              ><td>Controls icon and color theme</td></tr
            >
            <tr
              ><td><code>variant</code></td><td><code>ToastVariant</code></td
              ><td><code>"solid"</code></td><td>Visual style</td></tr
            >
            <tr
              ><td><code>icon</code></td><td><code>string | null</code></td><td
                ><code>undefined</code></td
              ><td>Custom SVG string, or <code>null</code> to hide</td></tr
            >
            <tr
              ><td><code>color</code></td><td><code>string</code></td><td
                ><code>undefined</code></td
              ><td>Custom CSS color for the accent</td></tr
            >
            <tr
              ><td><code>gradientColors</code></td><td><code>string[]</code></td
              ><td><code>undefined</code></td><td
                >Array of colors for gradient background</td
              ></tr
            >
            <tr
              ><td><code>duration</code></td><td><code>number</code></td><td
                ><code>4000</code></td
              ><td>Time in ms before auto-dismiss</td></tr
            >
          </tbody>
        </table>

        <div class="code-block">
          <button class="copy-btn" aria-label="Copy">
            <Icon name="copy" />
          </button>
          <pre><code>type ToastType    = "default" | "success" | "error" | "warning" | "info";
type ToastVariant = "solid" | "soft" | "outline" | "glass";</code></pre>
        </div>
      </section>
    </main>
  </div>
</Layout>

<script is:inline>
  // Tab switching
  document.querySelectorAll(".tab-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var tab = btn.dataset.tab;
      var parent = btn.closest(".code-tabs");
      parent.querySelectorAll(".tab-btn").forEach(function (b) {
        b.classList.remove("active");
      });
      btn.classList.add("active");
      parent.querySelectorAll("[data-tab-content]").forEach(function (block) {
        block.classList.toggle("hidden", block.dataset.tabContent !== tab);
      });
    });
  });

  // Copy buttons
  document.querySelectorAll(".copy-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var code = btn.closest(".code-block").querySelector("code");
      if (!code) return;
      navigator.clipboard.writeText(code.innerText).then(function () {
        btn.classList.add("copied");
        setTimeout(function () {
          btn.classList.remove("copied");
        }, 1800);
      });
    });
  });

  // Active sidebar link on scroll
  var observer = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          document.querySelectorAll(".sidebar-link").forEach(function (l) {
            l.classList.remove("active");
          });
          var active = document.querySelector(
            '.sidebar-link[href="#' + entry.target.id + '"]',
          );
          if (active) active.classList.add("active");
        }
      });
    },
    { rootMargin: "-20% 0px -70% 0px" },
  );

  document.querySelectorAll(".doc-section").forEach(function (s) {
    observer.observe(s);
  });
</script>

<style>
  /* ── Layout ── */
  .docs-page {
    display: grid;
    grid-template-columns: 220px 1fr;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    min-height: 100vh;
    font-family: var(--font-main);
  }

  /* ── Sidebar ─────────────────────────────────────────────── */
  .sidebar {
    position: sticky;
    top: 4rem;
    height: fit-content;
    padding: 2.5rem 1.5rem 2.5rem 0;
    border-right: 1px solid
      color-mix(in srgb, var(--text-color) 8%, transparent);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .sidebar-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-top: 1.25rem;
    margin-bottom: 0.25rem;
    padding-left: 0.75rem;
    color: var(--text-color);
  }
  .sidebar-label:first-child {
    margin-top: 0;
  }

  .sidebar-link {
    font-size: 0.85rem;
    color: var(--text-color);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    opacity: 0.55;
    transition:
      opacity 0.15s,
      background 0.15s;
  }
  .sidebar-link:hover {
    opacity: 0.9;
  }
  .sidebar-link.active {
    opacity: 1;
    background: color-mix(in srgb, var(--text-color) 6%, transparent);
    font-weight: 500;
  }

  /* ── Content ─────────────────────────────────────────────── */
  .docs-content {
    padding: 2.5rem 0 4rem 3rem;
    min-width: 0;
  }

  .docs-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid
      color-mix(in srgb, var(--text-color) 8%, transparent);
  }

  .docs-header h1 {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
    font-family: var(--font-main);
  }

  .docs-intro {
    font-size: 1rem;
    opacity: 0.6;
    line-height: 1.6;
    max-width: 520px;
    margin: 0;
  }

  /* ── Sections ─────────────────────────────────────────────── */
  .doc-section {
    margin-bottom: 3.5rem;
    scroll-margin-top: 5rem;
  }

  .doc-section h2 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-main);
  }

  .doc-section h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    opacity: 0.8;
    font-family: var(--font-main);
  }

  .section-icon {
    font-size: 1rem;
  }

  .doc-section p {
    font-size: 0.9rem;
    opacity: 0.65;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .doc-section p code,
  .doc-section li code,
  .callout code {
    font-family: var(--font-code);
    font-size: 0.8em;
    background: color-mix(in srgb, var(--text-color) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--text-color) 10%, transparent);
    padding: 0.1em 0.4em;
    border-radius: 4px;
  }

  /* ── Code Blocks ─────────────────────────────────────────── */
  .code-block {
    position: relative;
    background: color-mix(in srgb, var(--text-color) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--text-color) 8%, transparent);
    border-radius: 10px;
    margin: 0.75rem 0 1.25rem;
    overflow: hidden;
  }

  .code-filename {
    font-size: 0.72rem;
    font-family: var(--font-code);
    opacity: 0.4;
    padding: 0.55rem 1rem 0;
  }

  pre {
    margin: 0;
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }

  pre code {
    font-family: var(--font-code);
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--text-color);
  }

  /* Syntax tokens */
  .token-comment {
    opacity: 0.35;
    font-style: italic;
  }
  .token-keyword {
    color: #c792ea;
  }
  .token-string {
    color: #c3e88d;
  }
  .token-fn {
    color: #82aaff;
  }
  .token-type {
    color: #ffcb6b;
  }
  .token-number {
    color: #f78c6c;
  }
  .token-property {
