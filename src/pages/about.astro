                  d="M49.0007 8.22266C49.7633 9.52974 50.0499 11.0466 50.6232 14.0804L64.2015 86.0622C58.3307 83.063 51.7224 81.0938 44.7924 80.5438L35.6607 32.5371C35.4982 31.6921 34.7366 31.0871 33.8749 31.0988C33.0191 31.1104 32.2799 31.7271 32.1449 32.5788L24.1807 80.4554C17.1649 80.9871 10.4949 82.9596 4.56152 85.9946L18.4874 14.0479C19.069 11.0241 19.3574 9.51408 20.1224 8.21199C20.7999 7.07074 21.7891 6.15158 22.9724 5.56241C24.3166 4.89325 25.8524 4.69408 28.9241 4.29575L40.3657 2.84075C41.9849 2.63408 42.7941 2.53075 43.5299 2.59908C44.1807 2.65908 44.8132 2.83491 45.3966 3.11741C46.0566 3.43658 46.6382 3.94908 47.8016 4.97408L49.0007 8.22266Z"
