---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — toastro">
  <div class="about-page">
    <!-- ── Hero ── -->
    <section class="hero">
      <div id="particles-hero" class="particles-bg"></div>
      <div class="hero-inner">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          <span>Open Source · MIT Licensed</span>
        </div>
        <h1 class="hero-title">
          <span class="title-line">the toast lib</span>
          <span class="title-line accent">Astro deserved.</span>
        </h1>
        <p class="hero-sub">
          Beautiful, zero-dependency toast notifications for Astro.<br />
          No framework. No opinions. Just bread. 🍞
        </p>
        <div class="hero-links">
          <a href="/docs" class="btn-primary">Read the docs</a>
          <a
            href="https://github.com/your-user/toastro"
            target="_blank"
            rel="noopener"
            class="btn-ghost"
          >
            <!-- GitHub -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
      <div class="hero-scroll-hint">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          width="20"
          height="20"
        >
          <path d="M12 5v14M5 12l7 7 7-7"></path>
        </svg>
      </div>
    </section>

    <!-- ── What ── -->
    <section class="section what-section">
      <div class="section-inner">
        <div class="label-tag">What is toastro?</div>
        <div class="what-grid">
          <div class="what-text">
            <h2>A minimal toast library, built for <em>Astro</em>.</h2>
            <p>
              Most toast libraries assume you're in React, Vue, or Svelte land.
              Toastro was built from scratch for Astro — no framework adapter
              needed, no extra runtime overhead, no opinions about your stack.
            </p>
            <p>
              Drop <code>&lt;ToastContainer /&gt;</code> into your layout once, call
              <code>window.showToast()</code> from anywhere. That's it.
            </p>
          </div>
          <div class="what-features">
            <div class="feat-item">
              <span class="feat-icon">⚡</span>
              <div>
                <strong>Zero dependencies</strong>
                <span>Pure web platform APIs. No runtime bloat.</span>
              </div>
            </div>
            <div class="feat-item">
              <span class="feat-icon">🎨</span>
              <div>
                <strong>4 variants × 5 types</strong>
                <span>solid, soft, outline, glass — all composable.</span>
              </div>
            </div>
            <div class="feat-item">
              <span class="feat-icon">🌍</span>
              <div>
                <strong>Global API</strong>
                <span>Works from any script, island, or framework.</span>
              </div>
            </div>
            <div class="feat-item">
              <span class="feat-icon">🎭</span>
              <div>
                <strong>CSS-variable theming</strong>
                <span>Inherits your design system automatically.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Stack ── -->
    <section class="section stack-section">
      <div class="section-inner">
        <div class="label-tag">Built with</div>
        <h2 class="section-title">The stack behind toastro</h2>
        <p class="section-sub">
          Four tools. Each chosen because it's the best at what it does.
        </p>

