---
import Layout from "@layouts/Layout.astro";
import { changelog } from "@data/changelog";
import Button from "@ui/Button.astro"
import Icon from "@ui/Icon.astro"

// Ordenar de más reciente a más antiguo
const releases = [...changelog].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Etiquetar current automáticamente al primero
releases.forEach((r, i) => {
  if (!r.status) r.status = i === 0 ? "current" : "past";
});

// Formatear fecha legible
function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

// Colores y labels por tipo de cambio
const typeConfig: Record<string, { label: string; color: string }> = {
  feat:  { label: "feat",  color: "var(--status-success)" },
  fix:   { label: "fix",   color: "var(--status-error)"   },
  perf:  { label: "perf",  color: "var(--status-info)"    },
  break: { label: "break", color: "var(--status-warning)"  },
  docs:  { label: "docs",  color: "var(--status-neutral)"  },
  chore: { label: "chore", color: "var(--status-neutral)"  },
};
---

<Layout title="Changelog — toastro">
  <div class="changelog-page">

    <!-- Header -->
    <div class="cl-header">
     <Button
        href="/"
        variant="ghost"
      >
        <Icon name="arrowLeft" />Back to home
      </Button>

      <div class="cl-title-block">
        <span class="cl-eyebrow">Changelog</span>
        <h1>What's new in toastro</h1>
        <p>Every release, documented. From first slice to last crumb.</p>
      </div>
    </div>

    <!-- Timeline -->
    <div class="timeline">
      {releases.map((release, index) => (
        <div class:list={["tl-entry", release.status === "current" && "tl-entry--current"]}>

          <!-- Spine -->
          <div class="tl-spine">
            <div class="tl-dot">
              {release.status === "current" && (
                <div class="tl-dot-ring" />
              )}
            </div>
            {index < releases.length - 1 && <div class="tl-line" />}
          </div>

          <!-- Content -->
          <div class="tl-content">
            <div class="tl-meta">
              <span class="tl-version">v{release.version}</span>
              {release.status === "current" && (
                <span class="tl-badge">Latest</span>
              )}
              <span class="tl-date">{formatDate(release.date)}</span>
            </div>

            <h2 class="tl-title">{release.title}</h2>

            {release.description && (
              <p class="tl-desc">{release.description}</p>
            )}

            <ul class="tl-changes">
              {release.changes.map((change) => {
                const cfg = typeConfig[change.type] ?? typeConfig.chore;
                return (
                  <li class="tl-change">
                    <span
                      class="tl-type"
                      style={`color: ${cfg.color}; background: color-mix(in srgb, ${cfg.color} 10%, transparent); border-color: color-mix(in srgb, ${cfg.color} 20%, transparent);`}
                    >
                      {cfg.label}
                    </span>
                    <span class="tl-change-text">{change.text}</span>
                  </li>
                );
              })}
            </ul>
          </div>

        </div>
      ))}

      <!-- Future placeholder -->
      <div class="tl-entry tl-entry--future">
        <div class="tl-spine">
          <div class="tl-dot tl-dot--future" />
        </div>
        <div class="tl-content tl-content--future">
          <span class="tl-version" style="opacity:0.3">v0.2.0</span>
          <p class="tl-future-text">More toasts incoming 🍞</p>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  /* ── Page layout ── */
  .changelog-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    font-family: var(--font-main);
  }

  /* ── Header ── */
  .cl-header {
    margin-bottom: 3.5rem;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    padding: 0.45rem 0.85rem;
    border-radius: 7px;
    border: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
    background: transparent;
    opacity: 0.6;
    transition: opacity 0.15s, background 0.15s;
    margin-bottom: 2.5rem;
  }

  .btn-ghost:hover {
    opacity: 1;
    background: color-mix(in srgb, var(--text) 5%, transparent);
  }

  .cl-eyebrow {
    display: block;
    font-size: 0.65rem;
    font-family: var(--font-code);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    opacity: 0.75;
    margin-bottom: 0.6rem;
  }

  .cl-title-block h1 {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  .cl-title-block p {
    font-size: 0.92rem;
    opacity: 0.45;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Timeline ── */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .tl-entry {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 0 1.25rem;
    position: relative;
  }

  /* ── Spine ── */
  .tl-spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 3px;
  }

  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--text) 20%, transparent);
    border: 2px solid color-mix(in srgb, var(--text) 30%, transparent);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition: background 0.2s;
  }

  .tl-entry--current .tl-dot {
    background: var(--brand);
    border-color: var(--brand);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 20%, transparent);
  }

  .tl-dot-ring {
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1.5px solid color-mix(in srgb, var(--brand) 35%, transparent);
    animation: ring-pulse 2.5s ease-in-out infinite;
  }

  .tl-dot--future {
    background: transparent;
    border: 2px dashed color-mix(in srgb, var(--text) 15%, transparent);
  }

  .tl-line {
    flex: 1;
    width: 2px;
    background: color-mix(in srgb, var(--text) 8%, transparent);
    margin: 6px 0;
    min-height: 2rem;
  }

  .tl-entry--future .tl-line {
    background: repeating-linear-gradient(
      to bottom,
      color-mix(in srgb, var(--text) 10%, transparent) 0px,
      color-mix(in srgb, var(--text) 10%, transparent) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  /* ── Content ── */
  .tl-content {
    padding-bottom: 2.75rem;
  }

  .tl-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .tl-version {
    font-family: var(--font-code);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text);
    opacity: 0.85;
  }

  .tl-badge {
    font-size: 0.6rem;
    font-family: var(--font-code);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18rem 0.55rem;
    border-radius: 99px;
    background: color-mix(in srgb, var(--brand) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand) 25%, transparent);
    color: var(--brand);
  }

  .tl-date {
    font-size: 0.75rem;
    opacity: 0.35;
    font-style: italic;
  }

  .tl-title {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.6rem;
    line-height: 1.25;
  }

  .tl-entry--current .tl-title {
    font-size: 1.35rem;
  }

  .tl-desc {
    font-size: 0.85rem;
    opacity: 0.5;
    line-height: 1.7;
    margin: 0 0 1rem;
    max-width: 520px;
  }

  /* ── Change list ── */
  .tl-changes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .tl-change {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    font-size: 0.83rem;
    line-height: 1.5;
  }

  .tl-type {
    display: inline-block;
    font-family: var(--font-code);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    border: 1px solid;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .tl-change-text {
    opacity: 0.7;
  }

  /* ── Future entry ── */
  .tl-content--future {
    padding-bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tl-future-text {
    font-size: 0.8rem;
    opacity: 0.3;
    margin: 0;
    font-style: italic;
  }

  /* ── Animations ── */
  @keyframes ring-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50%       { opacity: 0.2; transform: scale(1.3); }
  }

  /* ── Responsive ── */
  @media (max-width: 520px) {
    .changelog-page { padding: 2rem 1rem 4rem; }
    .tl-entry { grid-template-columns: 20px 1fr; gap: 0 1rem; }
    .tl-title { font-size: 1.05rem; }
    .tl-entry--current .tl-title { font-size: 1.15rem; }
  }
</style>
